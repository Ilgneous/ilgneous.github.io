---
// Station — a case-study chapter marker. An ember node on a vertical rail
// (the "trajectory" running down the page), paired with a mono station label
// and heading. The rail line fades at the last station via `tail`.
interface Props {
  station: string;       // e.g. "Station 01 · System"
  title: string;
  fade?: boolean;        // last station: fade the trailing rail to transparent
  class?: string;
}
const { station, title, fade = false, class: className = "" } = Astro.props;
---

<div class:list={["station", className]}>
  <div class="station__rail">
    <div class="station__node"></div>
    <div class:list={["station__line", fade && "station__line--fade"]}></div>
  </div>
  <div class="station__body">
    <div class="station__label">{station}</div>
    <h2 class="station__title">{title}</h2>
    <slot />
  </div>
</div>

<style>
  .station {
    display: grid;
    grid-template-columns: 56px 1fr;
    gap: 22px;
  }
  .station__rail {
    display: flex;
    flex-direction: column;
    align-items: center;
    padding-top: 6px;
  }
  .station__node {
    width: 15px;
    height: 15px;
    border-radius: 99px;
    background: var(--accent);
    box-shadow: var(--glow-ember-md);
    border: 2px solid var(--bg);
    flex-shrink: 0;
  }
  .station__line {
    flex: 1;
    width: 2px;
    background: var(--accent-line);
    margin-top: 6px;
  }
  .station__line--fade {
    background: linear-gradient(var(--accent-line), transparent);
  }
  .station__body { padding-bottom: 60px; }
  .station__label {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--text-accent);
  }
  .station__title {
    font-size: clamp(34px, 4.4vw, 52px);
    font-weight: 600;
    letter-spacing: -0.025em;
    color: var(--text-display);
    margin: 10px 0 0;
    line-height: 1;
  }

  @media (max-width: 640px) {
    .station { grid-template-columns: 32px 1fr; gap: 16px; }
    .station__body { padding-bottom: 44px; }
  }
</style>
