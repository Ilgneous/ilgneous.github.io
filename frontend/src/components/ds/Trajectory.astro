---
// Trajectory — a vertical mission-profile timeline. Each phase is a marker on
// a rail; the "current" phase pulses ember, "target" phases use a dashed
// marker. Used for project roadmaps and the "Now" panel.
interface Phase {
  chip?: string;
  title: string;
  detail?: string;
  state?: "done" | "current" | "target";
}
interface Props {
  phases?: readonly Phase[];
}
const { phases = [] } = Astro.props;

function marker(state: string) {
  if (state === "current") {
    return {
      bg: "var(--ember-400)",
      border: "var(--ember-300)",
      style: "solid",
      shadow: "0 0 0 3px var(--accent-soft), var(--glow-ember-sm)",
      anim: "ilg-pulse 2.4s var(--ease-out) infinite",
    };
  }
  if (state === "target") {
    return { bg: "transparent", border: "rgba(255,179,122,0.5)", style: "dashed", shadow: "none", anim: "none" };
  }
  return { bg: "var(--surface-raised)", border: "var(--border-strong)", style: "solid", shadow: "none", anim: "none" };
}
---

<ol class="traj">
  {phases.map((p, i) => {
    const last = i === phases.length - 1;
    const state = p.state ?? "done";
    const m = marker(state);
    return (
      <li class="traj__item" class:list={[last && "traj__item--last"]}>
        <div class="traj__rail">
          {!last ? <span class="traj__line"></span> : null}
          <span
            class="traj__marker"
            style={`background:${m.bg}; border:1.5px ${m.style} ${m.border}; box-shadow:${m.shadow}; animation:${m.anim};`}
          ></span>
        </div>
        <div class="traj__content">
          <div class="traj__head">
            {p.chip ? <span class="traj__chip">{p.chip}</span> : null}
            <span class:list={["traj__title", state === "done" && "traj__title--done"]}>{p.title}</span>
          </div>
          {p.detail ? <p class="traj__detail">{p.detail}</p> : null}
        </div>
      </li>
    );
  })}
</ol>

<style>
  .traj { list-style: none; margin: 0; padding: 0; }
  .traj__item {
    display: grid;
    grid-template-columns: 28px 1fr;
    gap: var(--space-4);
    padding-bottom: var(--space-6);
  }
  .traj__item--last { padding-bottom: 0; }
  .traj__rail { position: relative; width: 28px; }
  .traj__line {
    position: absolute;
    left: 13px;
    top: 18px;
    bottom: calc(-1 * var(--space-6));
    width: 1px;
    background: linear-gradient(to bottom, var(--accent-line), rgba(242, 106, 40, 0.12));
  }
  .traj__marker {
    position: absolute;
    left: 7px;
    top: 3px;
    width: 13px;
    height: 13px;
    border-radius: var(--radius-pill);
    box-sizing: border-box;
  }
  .traj__content {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    padding-top: 1px;
  }
  .traj__head {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    flex-wrap: wrap;
  }
  .traj__chip {
    font-family: var(--font-mono);
    font-size: var(--text-2xs);
    padding: 2px 7px;
    border-radius: var(--radius-xs);
    background: var(--surface-raised);
    border: 1px solid var(--border);
    color: var(--text-muted);
    letter-spacing: var(--tracking-mono);
  }
  .traj__title {
    font-family: var(--font-display);
    font-size: var(--text-base);
    font-weight: var(--weight-semibold);
    color: var(--text-display);
  }
  .traj__title--done { color: var(--text-secondary); }
  .traj__detail {
    margin: 0;
    font-size: var(--text-sm);
    color: var(--text-muted);
    line-height: var(--leading-snug);
  }
</style>
