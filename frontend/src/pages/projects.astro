---
import Base from "../layouts/Base.astro";
import Eyebrow from "../components/ds/Eyebrow.astro";
import SectionDivider from "../components/ds/SectionDivider.astro";
import ProjectCard from "../components/ds/ProjectCard.astro";

const base = "/assets/projects/";

const projects = [
  {
    index: "01", title: "Project Ventris", status: "active" as const, href: "/projects/ventris",
    summary: "This website!",
    highlight: "website!", image: null,
    tech: ["Astro", "Svelte", "JavaScript", "CSS"],
  },
  {
    index: "02", title: "LEGEND Lab", status: null, href: "/projects/legend-wls-fiber-characterization",
    summary: "Transformer Model for Pulse Shape Discrimination for radioactive sources and WLS Fiber Characterization for emission spectra and attenuation.",
    highlight: "Transformer Model", image: base + "UVvBlueLED.png",
    tech: ["Transformer", "PyTorch", "Signal Processing", "Python", "Optics", "SiPM", "DAQ"],
  },
  {
    index: "03", title: "Surrogate ML for MHD", status: null, href: "/projects/surrogate-ml-model-mhd",
    summary: "Feed-forward surrogate emulating MHD sims at >98% fidelity — turnaround under 20 min.",
    highlight: ">98% fidelity", image: base + "LBFGS.png",
    tech: ["Neural Network", "MATLAB", "Python", "Plasma Physics"],
  },
  {
    index: "04", title: "E-Bike Boost Converter", status: null, href: "/projects/boost-converter",
    summary: "Designed, simulated, and tested a high-efficiency DC-DC boost for an e-bike battery.",
    highlight: "high-efficiency DC-DC boost", image: base + "BoostPCB.png",
    tech: ["LTspice", "KiCad", "Power Electronics", "PCB Design"],
  },
  {
    index: "05", title: "IOT Smart Alarm Clock", status: null, href: "#",
    summary: "MQTT driven alarm clock with a ESP8266 and a web-based dashboard for scheduling and control.",
    highlight: null, image: null,
    tech: ["C", "ESP8266", "MQTT", "SPI", "Network Protocols"],
  },
  {
    index: "06", title: "DDR-AR", status: null, href: "/projects/vision-dance-game-hacktx",
    summary: "Augmented Reality Dance Dance Revolution on a laptop with a webcam and OpenCV.",
    highlight: null, image: null,
    tech: ["Computer Vision", "OpenCV", "Python", "AR", "HTML", "CSS", "JavaScript"],
  },
  {
    index: "07", title: "Weather Damage Forecasting", status: null, href: "/projects/weather-damage-forecasting",
    summary: "",
    highlight: null, image: null,
    tech: ["Python", "Machine Learning", "Data Science", "Pandas", "NumPy", "PyTorch", "Scikit-learn"],
  },
];
---

<Base
  title="Projects | Igneous"
  description="Selected work across ECE, physics, robotics, and systems — with notes and build details."
>
  <section class="section container">
    <SectionDivider />
    <div class="section__head">
      <div>
        <Eyebrow color="accent">Lab log</Eyebrow>
        <h2 class="section__title">Projects &amp; experiments</h2>
      </div>
      <span class="section__aside">{projects.length} entries</span>
    </div>
    <div class="lab-grid">
      {projects.map((p) => (
        <ProjectCard
          index={p.index}
          title={p.title}
          summary={p.summary}
          highlight={p.highlight}
          image={p.image}
          tech={p.tech}
          status={p.status}
          href={p.href}
        />
      ))}
    </div>
  </section>
</Base>

<style>
  .container { max-width: var(--container); margin: 0 auto; }
  .section { padding: 8px 32px 64px; }
  .section__head {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    flex-wrap: wrap;
    gap: 16px;
    margin-bottom: 28px;
  }
  .section__title {
    font-size: clamp(30px, 4vw, 46px);
    font-weight: 600;
    letter-spacing: -0.025em;
    color: var(--text-display);
    margin: 14px 0 0;
  }
  .section__aside {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--text-faint);
    padding-bottom: 6px;
  }
  .lab-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 20px;
  }
  @media (max-width: 560px) {
    .section { padding: 8px 18px 48px; }
  }
</style>
