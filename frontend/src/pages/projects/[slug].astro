---
import Base from "../../layouts/Base.astro";
import SectionDivider from "../../components/ds/SectionDivider.astro";
import Tag from "../../components/ds/Tag.astro";
import Button from "../../components/ds/Button.astro";
import { getEntry, getCollection } from "astro:content";

export async function getStaticPaths() {
  const items = await getCollection("projects");
  return items.map((e) => ({ params: { slug: e.slug } }));
}

const { slug } = Astro.params;
const entry = await getEntry("projects", slug!);
if (!entry) throw new Error(`Project not found: ${slug}`);

const { data } = entry;
const { Content } = await entry.render();

const dateStr = data.date
  ? new Date(data.date).toLocaleDateString(undefined, { year: "numeric", month: "long", day: "numeric" })
  : null;
---

<Base
  title={`${data.title} · Ilgneous`}
  description={data.summary ?? "Project details and write-up."}
>
  <div class="project-wrap container">
    <!-- Breadcrumb -->
    <nav class="breadcrumb">
      <a href="/projects" class="breadcrumb__link">← All projects</a>
    </nav>

    <SectionDivider />

    <!-- Hero -->
    <header class="project-hero">
      <h1 class="project-hero__title">{data.title}</h1>
      {data.summary && <p class="project-hero__summary">{data.summary}</p>}
      <div class="project-hero__meta">
        {dateStr && <span class="project-hero__date">{dateStr}</span>}
        {data.tech?.length ? (
          <div class="project-hero__tags">
            {data.tech.map((t: string) => <Tag size="sm" interactive={false}>{t}</Tag>)}
          </div>
        ) : null}
      </div>
      {(data.repo || data.demo) && (
        <div class="project-hero__links">
          {data.repo && <Button variant="ghost" size="sm" href={data.repo} target="_blank" rel="noopener noreferrer">Source code ↗</Button>}
          {data.demo && <Button variant="signal" size="sm" href={data.demo} target="_blank" rel="noopener noreferrer">Live demo ↗</Button>}
        </div>
      )}
    </header>

    <SectionDivider />

    <!-- Markdown content -->
    <article class="prose">
      <Content />
    </article>
  </div>
</Base>

<style>
  .container { max-width: var(--container-narrow); margin: 0 auto; }
  .project-wrap { padding: 32px 32px 80px; }

  .breadcrumb { margin-bottom: 28px; }
  .breadcrumb__link {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    letter-spacing: 0.06em;
    color: var(--text-faint);
    text-decoration: none;
    transition: color var(--dur-fast) var(--ease-out);
  }
  .breadcrumb__link:hover { color: var(--text-secondary); }

  .project-hero { padding: 20px 0 0; }
  .project-hero__title {
    font-size: clamp(32px, 5vw, 56px);
    font-weight: 600;
    letter-spacing: -0.03em;
    line-height: 1;
    color: var(--text-display);
    margin: 0 0 16px;
  }
  .project-hero__summary {
    font-size: var(--text-md);
    line-height: var(--leading-relaxed);
    color: var(--text-secondary);
    max-width: 60ch;
    margin: 0 0 20px;
  }
  .project-hero__meta { display: flex; flex-direction: column; gap: 12px; }
  .project-hero__date {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--text-faint);
    letter-spacing: 0.06em;
  }
  .project-hero__tags { display: flex; flex-wrap: wrap; gap: 6px; }
  .project-hero__links { display: flex; gap: 10px; flex-wrap: wrap; margin-top: 20px; }

  /* Prose — markdown body */
  .prose {
    color: var(--text-secondary);
    font-size: var(--text-base);
    line-height: var(--leading-relaxed);
    padding: 12px 0 0;
  }
  .prose :global(h2) {
    font-size: var(--text-xl);
    font-weight: 600;
    color: var(--text-display);
    letter-spacing: var(--tracking-tight);
    margin: 40px 0 12px;
  }
  .prose :global(h3) {
    font-size: var(--text-lg);
    font-weight: 600;
    color: var(--text-display);
    margin: 28px 0 10px;
  }
  .prose :global(p) { margin: 0 0 16px; }
  .prose :global(ul), .prose :global(ol) {
    padding-left: 20px;
    margin: 0 0 16px;
    display: flex;
    flex-direction: column;
    gap: 6px;
  }
  .prose :global(li) { color: var(--text-secondary); }
  .prose :global(a) { color: var(--text-accent); text-decoration: underline; text-underline-offset: 3px; }
  .prose :global(a:hover) { color: var(--ember-300); }
  .prose :global(code) {
    font-family: var(--font-mono);
    font-size: 0.88em;
    background: var(--surface-raised);
    border: 1px solid var(--border);
    border-radius: var(--radius-xs);
    padding: 1px 5px;
    color: var(--text-primary);
  }
  .prose :global(pre) {
    background: var(--surface-sunken);
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    padding: 16px 20px;
    overflow-x: auto;
    margin: 0 0 20px;
  }
  .prose :global(pre code) { background: none; border: none; padding: 0; font-size: var(--text-sm); }
  .prose :global(img) {
    border-radius: var(--radius-lg);
    border: 1px solid var(--border);
    margin: 20px 0;
    max-width: 100%;
  }
  .prose :global(hr) { margin: 32px 0; }
  .prose :global(blockquote) {
    border-left: 2px solid var(--accent-line);
    padding: 8px 16px;
    margin: 0 0 16px;
    color: var(--text-muted);
    font-style: italic;
  }
  .prose :global(strong) { color: var(--text-primary); font-weight: 600; }

  @media (max-width: 560px) {
    .project-wrap { padding: 20px 18px 60px; }
  }
</style>
