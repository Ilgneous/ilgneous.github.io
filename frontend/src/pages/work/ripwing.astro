          <h2 class="cta__title">Want the deep dive on RipWing?</h2>
          <p class="cta__body">
            Happy to walk the simulator, the Cargo-enforced layering, the RTIC scheduling case,
            or the ML-monitors-classical-actuates split.
          </p>
        </div>
        <div class="cta__actions">
          <Button variant="primary" size="lg" href={githubUrl}>View the code →</Button>
          <Button variant="ghost" size="lg" href="/">Back to portfolio</Button>
        </div>
      </div>
    </div>
  </section>
</Base>

<style>
  .container { max-width: var(--container); margin: 0 auto; }
  .measure { max-width: 1080px; margin: 0 auto; padding: 0 32px; }
  .section { padding: 8px 32px; }
  .section--cta { padding-top: 24px; }

  :global(.ink) { color: var(--text-display); }
  .ink-soft { color: var(--text-secondary); }
  .eqn { font-style: italic; }

  .accent-signal {
    --accent: var(--signal-500); --accent-hover: var(--signal-400); --accent-line: rgba(62,141,160,0.35);
    --accent-soft: rgba(62,141,160,0.1); --text-accent: var(--signal-400);
  }
  .accent-amber {
    --accent: var(--status-caution); --accent-hover: var(--status-caution); --accent-line: rgba(232,162,58,0.38);
    --accent-soft: rgba(232,162,58,0.1); --text-accent: var(--status-caution);
  }

  .prose { font-size: 16px; line-height: 1.7; color: var(--text-secondary); margin: 0; }
  .prose--wide { max-width: 64ch; }
  .prose--gap { margin-top: 24px; }

  .split { display: grid; grid-template-columns: 1fr 1fr; gap: 32px; align-items: center; margin-top: 30px; }
  .split--top { align-items: start; }

  /* ── HERO ── */
  .hero { position: relative; overflow: hidden; padding: 72px 32px 56px; }
  .hero__grid {
    position: absolute; inset: 0; pointer-events: none;
    -webkit-mask-image: radial-gradient(120% 92% at 50% 0%, #000 35%, transparent 80%);
    mask-image: radial-gradient(120% 92% at 50% 0%, #000 35%, transparent 80%);
  }
  .hero__spotlight { position: absolute; inset: 0; pointer-events: none; background: var(--spotlight-ember); }
  .hero__inner { position: relative; display: grid; grid-template-columns: 1.55fr 1fr; gap: 52px; align-items: start; }
  .hero__badges { display: flex; align-items: center; gap: 14px; flex-wrap: wrap; margin-bottom: 20px; }
  .hero__codename {
    font-family: var(--font-mono); font-size: 12px; letter-spacing: 0.18em;
    text-transform: uppercase; color: var(--text-faint); margin-bottom: 10px;
  }
  .hero__plus { color: var(--signal-400); }
  .hero__title {
    font-size: clamp(48px, 6.4vw, 92px); font-weight: 600; line-height: 0.92;
    letter-spacing: -0.03em; color: var(--text-display); margin: 0;
    font-feature-settings: var(--display-features);
  }
  .hero__title-accent { color: var(--ember-500); }
  .hero__lead { max-width: 54ch; margin-top: 22px; font-size: clamp(18px, 1.6vw, 21px); line-height: 1.5; color: var(--text-secondary); }
  .hero__lead .accent { color: var(--text-accent); font-weight: 600; }
  .hero__actions { display: flex; gap: 14px; margin-top: 28px; flex-wrap: wrap; }

  .hero__builtwith { position: relative; margin-top: 34px; display: flex; flex-wrap: wrap; gap: 8px; align-items: center; }
  .hero__builtwith-label { font-family: var(--font-mono); font-size: 11px; letter-spacing: 0.14em; text-transform: uppercase; color: var(--text-faint); margin-right: 6px; }

  .meta-grid {
    display: grid; grid-template-columns: repeat(2, minmax(0, 1fr)); gap: 1px;
    margin-top: 32px; background: var(--border); border: 1px solid var(--border);
    border-radius: var(--radius-md); overflow: hidden;
  }
  .meta-cell { background: var(--surface-raised); padding: 16px 18px; }
  .meta-cell__key { font-family: var(--font-mono); font-size: 10px; letter-spacing: 0.2em; text-transform: uppercase; color: var(--text-faint); }
  .meta-cell__val { font-size: 15px; color: var(--text-secondary); margin-top: 6px; line-height: 1.4; }

  .legend__label { font-family: var(--font-mono); font-size: 11px; letter-spacing: 0.18em; text-transform: uppercase; color: var(--text-faint); margin-bottom: 6px; }
  .legend__intro { font-size: 14px; line-height: 1.5; color: var(--text-muted); margin-bottom: 18px; }

  .obj__row { display: flex; align-items: flex-start; gap: 14px; padding: 11px 0; border-top: 1px solid var(--hairline); }
  .obj__row--last { border-bottom: 1px solid var(--hairline); }
  .obj__n { font-family: var(--font-mono); font-size: 12px; width: 22px; flex-shrink: 0; font-weight: 600; }
  .obj__text { flex: 1; font-size: 14px; color: var(--text-secondary); line-height: 1.45; }

  /* ── PREMISE (00) ── */
  .premise { display: grid; grid-template-columns: 200px 1fr; gap: 36px; padding-top: 8px; }
  .premise__num { font-family: var(--font-mono); font-size: 44px; font-weight: 600; color: var(--paper-hairline-strong, rgba(236,231,217,0.15)); line-height: 1; letter-spacing: -0.02em; }
  .premise__title { font-size: 26px; font-weight: 600; letter-spacing: -0.02em; color: var(--text-display); margin: 6px 0 0; line-height: 1.1; }
  .premise__lead { margin: 0; font-size: clamp(19px, 2vw, 24px); line-height: 1.5; letter-spacing: -0.01em; color: var(--text-secondary); text-wrap: pretty; }

  /* ── chapter header (rail + giant number) ── */
  .chapter { display: grid; grid-template-columns: 56px 1fr; gap: 22px; }
  .chapter__rail { display: flex; flex-direction: column; align-items: center; padding-top: 6px; }
  .chapter__dot {
    width: 15px; height: 15px; border-radius: 99px; background: var(--accent);
    box-shadow: 0 0 0 5px var(--accent-soft); border: 2px solid var(--bg); flex-shrink: 0;
  }
  .chapter__line { flex: 1; width: 2px; background: var(--accent-line); margin-top: 6px; }
  .chapter__body { padding-bottom: 56px; }
  .chapter__num { font-family: var(--font-mono); font-size: 44px; font-weight: 600; color: var(--accent-line); line-height: 1; letter-spacing: -0.02em; opacity: 0.75; }
  .chapter__title { font-size: clamp(34px, 4.4vw, 52px); font-weight: 600; letter-spacing: -0.025em; color: var(--text-display); margin: 6px 0 0; line-height: 1; }
  .chapter__lead { font-size: 18px; line-height: 1.55; color: var(--text-secondary); margin: 14px 0 0; max-width: 62ch; }

  .tuner { margin-top: 28px; }
  .figcaption { font-family: var(--font-mono); font-size: 11px; line-height: 1.6; letter-spacing: 0.04em; color: var(--text-faint); margin: 14px 4px 0; }

  /* ── key decision banner ── */
  .keydecision { margin: 36px 0; padding: 40px 32px; text-align: center; border-top: 2px solid var(--accent); border-bottom: 2px solid var(--accent); background: linear-gradient(var(--surface-raised), var(--accent-soft)); }
  .keydecision__kicker { font-family: var(--font-mono); font-size: 11px; letter-spacing: 0.24em; text-transform: uppercase; color: var(--text-accent); margin-bottom: 14px; }
  .keydecision__title { font-size: clamp(26px, 3.4vw, 42px); font-weight: 600; letter-spacing: -0.02em; color: var(--text-display); line-height: 1.12; max-width: 26ch; margin: 0 auto; }
  .keydecision__title .hl { color: var(--text-accent); }
  .keydecision__body { max-width: 64ch; margin: 18px auto 0; font-size: 16.5px; line-height: 1.65; color: var(--text-secondary); }

  /* ── equation figure ── */
  .eqnfig { margin: 22px 0 0; border: 1px solid var(--border); border-radius: var(--radius-md); overflow: hidden; background: var(--surface-sunken); }
  .eqnfig__bar { padding: 8px 16px; border-bottom: 1px solid var(--hairline); background: var(--surface-raised); font-family: var(--font-mono); font-size: 10.5px; letter-spacing: 0.14em; text-transform: uppercase; color: var(--text-faint); }
  .eqnfig__body { padding: 24px; display: flex; align-items: center; gap: 16px; flex-wrap: wrap; font-family: Georgia, "Times New Roman", serif; font-size: 21px; color: var(--text-display); }
  .eqnfig__body--center { justify-content: flex-start; }
  .eqnfig__body i { font-style: italic; }
  .eqnfig__note { font-family: var(--font-mono); font-size: 12px; color: var(--text-faint); }
  .eqnfig .hl { color: var(--text-accent); }

  /* ── comparison / decision tables ── */
  .matrix { margin: 24px 0 0; border: 1px solid var(--border); border-radius: var(--radius-md); overflow: hidden; background: var(--surface-sunken); }
  .matrix__bar { display: flex; align-items: center; justify-content: space-between; padding: 10px 16px; border-bottom: 1px solid var(--hairline); background: var(--surface-raised); font-family: var(--font-mono); font-size: 12px; color: var(--text-secondary); }
  .matrix__bar-faint { color: var(--text-faint); }
  .matrix__scroll { overflow-x: auto; }
  .matrix table { width: 100%; border-collapse: collapse; font-size: 13.5px; min-width: 480px; }
  .matrix thead tr { font-family: var(--font-mono); font-size: 10.5px; letter-spacing: 0.08em; text-transform: uppercase; color: var(--text-faint); }
  .matrix th { text-align: left; padding: 12px 16px; font-weight: 500; }
  .matrix th.center { text-align: center; }
  .matrix th.win-col { text-align: center; font-weight: 600; color: var(--text-accent); background: var(--accent-soft); }
  .matrix td { padding: 11px 16px; color: var(--text-secondary); }
  .matrix tbody tr { border-top: 1px solid var(--hairline); }
  .matrix td.center { text-align: center; }
  .matrix td.faint { color: var(--text-faint); }
  .matrix td.note { font-size: 13px; color: var(--text-muted); }
  .matrix td.rowlabel { color: var(--text-faint); font-family: var(--font-mono); font-size: 12px; }
  .matrix td.winner { color: var(--text-display); font-weight: 600; background: var(--accent-soft); text-align: center; }
  .matrix td.winner--signal { color: var(--text-display); font-weight: 500; background: var(--signal-soft); text-align: left; }
  .matrix__cap { padding: 11px 16px; border-top: 1px solid var(--hairline); font-family: var(--font-mono); font-size: 11px; color: var(--text-faint); margin: 0; }

  /* ── subhead (in-chapter sub-section) ── */
  .subhead { margin-top: 36px; border-top: 1px solid var(--hairline); padding-top: 30px; }
  .subhead__kicker { font-family: var(--font-mono); font-size: 11px; letter-spacing: 0.16em; text-transform: uppercase; color: var(--text-accent); }
  .subhead__title { font-size: clamp(22px, 2.4vw, 30px); font-weight: 600; letter-spacing: -0.02em; color: var(--text-display); margin: 12px 0 0; line-height: 1.1; }

  /* ── callouts (trap/choice/hazard/payoff) ── */
  .callout { border-radius: var(--radius-md); padding: 20px 22px; }
  .callout--critical { border: 1px solid rgba(229,96,77,0.35); border-left: 3px solid var(--status-critical); background: rgba(229,96,77,0.06); }
  .callout--ember { border: 1px solid var(--accent-line); border-left: 3px solid var(--ember-500); background: rgba(242,106,40,0.06); }
  .callout--amber { border: 1px solid var(--border); border-left: 3px solid var(--status-caution); background: var(--surface-raised); }
  .callout__kicker { font-family: var(--font-mono); font-size: 11px; letter-spacing: 0.14em; text-transform: uppercase; }
  .callout--critical .callout__kicker { color: var(--status-critical); }
  .callout--ember .callout__kicker { color: var(--ember-400); }
  .callout--amber .callout__kicker { color: var(--status-caution); }
  .callout__title { font-size: 16px; font-weight: 600; color: var(--text-display); margin: 8px 0 0; }
  .callout__body { font-size: 14.5px; line-height: 1.6; color: var(--text-secondary); margin: 10px 0 0; max-width: 66ch; }
  .callout__body--lg { font-size: 17px; line-height: 1.55; color: var(--text-secondary); max-width: 66ch; }

  /* ── card grids ── */
  .cards2 { display: grid; grid-template-columns: 1fr 1fr; gap: 18px; margin-top: 28px; }
  .cards3 { display: grid; grid-template-columns: repeat(3, 1fr); gap: 18px; margin-top: 22px; }
  .cards4 { display: grid; grid-template-columns: 1fr 1fr; gap: 18px; margin-top: 24px; }
  .card__kicker { font-family: var(--font-mono); font-size: 11px; letter-spacing: 0.12em; text-transform: uppercase; }
  .card__title { font-size: 17px; font-weight: 600; color: var(--text-display); margin: 7px 0 0; }
  .card__body { font-size: 15px; line-height: 1.6; color: var(--text-muted); margin: 12px 0 0; }
  .card__num-kicker { display: flex; align-items: center; gap: 10px; }
  .card__num { font-family: var(--font-mono); font-size: 12px; font-weight: 600; color: var(--ember-400); }

  /* ── layer stack ── */
  .layerstack { margin-top: 28px; border: 1px solid var(--border); border-radius: var(--radius-md); overflow: hidden; background: var(--surface-raised); }
  .layerstack__row { display: flex; align-items: center; gap: 16px; padding: 15px 18px; }
  .layerstack__row + .layerstack__row { border-top: 1px solid var(--hairline); }
  .layerstack__n { flex: 0 0 auto; width: 64px; font-family: var(--font-mono); font-size: 11px; font-weight: 600; }
  .layerstack__body { flex: 1; display: flex; flex-direction: column; }
  .layerstack__title { font-size: 15px; color: var(--text-display); font-weight: 600; }
  .layerstack__desc { font-size: 13.5px; color: var(--text-muted); margin-top: 2px; }
  .layerstack__tag { font-family: var(--font-mono); font-size: 11px; flex-shrink: 0; }

  /* ── rule list ── */
  .rulelist { display: flex; flex-direction: column; gap: 10px; }
  .rulelist__item { display: flex; align-items: flex-start; gap: 11px; padding: 13px 15px; border: 1px solid var(--border); border-radius: 10px; background: var(--surface-raised); }
  .rulelist__tag { font-family: var(--font-mono); font-size: 11px; color: var(--ember-400); flex: 0 0 auto; margin-top: 2px; }
  .rulelist__text { font-size: 14px; color: var(--text-secondary); line-height: 1.5; }

  /* ── priority ladder ── */
  .ladder { display: flex; flex-wrap: wrap; gap: 8px; margin-top: 18px; align-items: center; }
  .ladder__end { font-family: var(--font-mono); font-size: 11px; color: var(--text-faint); }
  .ladder__chip { font-family: var(--font-mono); font-size: 12px; padding: 6px 12px; border-radius: 8px; }
  .ladder__arrow { color: var(--text-faint); }

  /* ── listings ── */
  .listing { margin-top: 28px; }

  /* ── STATUS BOARD ── */
  .status__head { display: flex; align-items: baseline; justify-content: space-between; gap: 20px; flex-wrap: wrap; margin-bottom: 8px; }
  .status__title { font-size: clamp(30px, 4vw, 46px); font-weight: 600; letter-spacing: -0.025em; color: var(--text-display); margin: 12px 0 0; }
  .status__intro { max-width: 44ch; margin: 0; font-size: 15.5px; line-height: 1.6; color: var(--text-secondary); }
  .status { display: grid; grid-template-columns: 1fr 1fr; gap: 1px; margin-top: 26px; background: var(--border); border: 1px solid var(--border); border-radius: var(--radius-xl); overflow: hidden; }
  .status__col { background: var(--surface-raised); padding: 26px 28px; }
  .status__colhead { display: flex; align-items: center; gap: 9px; margin-bottom: 18px; }
  .status__dot { width: 8px; height: 8px; border-radius: 99px; }
  .status__label { font-family: var(--font-mono); font-size: 11px; letter-spacing: 0.12em; text-transform: uppercase; }
  .status__item { display: flex; align-items: flex-start; gap: 11px; padding: 5.5px 0; }
  .status__check { color: var(--status-nominal); font-family: var(--font-mono); font-size: 13px; flex: 0 0 auto; margin-top: 1px; }
  .status__num { color: var(--text-faint); font-family: var(--font-mono); font-size: 13px; flex: 0 0 auto; margin-top: 1px; }
  .status__text { font-size: 14.5px; color: var(--text-secondary); line-height: 1.45; }
  .status__text--muted { color: var(--text-muted); }
  .status__flag { color: var(--status-caution); }

  /* ── CTA ── */
  .cta { position: relative; overflow: hidden; border: 1px solid var(--border); border-radius: var(--radius-xl); background: var(--surface-raised); padding: 40px 36px; display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 24px; }
  .cta__spotlight { position: absolute; inset: 0; pointer-events: none; background: var(--spotlight-ember); }
  .cta__left { position: relative; }
  .cta__title { font-size: clamp(26px, 3vw, 38px); font-weight: 600; letter-spacing: -0.025em; color: var(--text-display); margin: 12px 0 0; line-height: 1.05; }
  .cta__body { font-size: 15.5px; line-height: 1.6; color: var(--text-muted); margin: 12px 0 0; max-width: 48ch; }
  .cta__actions { position: relative; display: flex; gap: 14px; flex-wrap: wrap; }

  /* ── Responsive ── */
  @media (max-width: 880px) {
    .hero__inner { grid-template-columns: 1fr; gap: 36px; }
    .split { grid-template-columns: 1fr; gap: 24px; }
    .premise { grid-template-columns: 1fr; gap: 16px; }
    .cards2, .cards3, .cards4 { grid-template-columns: 1fr; }
    .status { grid-template-columns: 1fr; }
  }
  @media (max-width: 640px) {
    .chapter { grid-template-columns: 32px 1fr; gap: 16px; }
