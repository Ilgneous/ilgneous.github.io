---
import Base from "../../layouts/Base.astro";
import Eyebrow from "../../components/ds/Eyebrow.astro";
import Button from "../../components/ds/Button.astro";
import Panel from "../../components/ds/Panel.astro";
import Tag from "../../components/ds/Tag.astro";
import Kpi from "../../components/ds/Kpi.astro";
import StatusBadge from "../../components/ds/StatusBadge.astro";
import SectionDivider from "../../components/ds/SectionDivider.astro";
import Trajectory from "../../components/ds/Trajectory.astro";
import Station from "../../components/ds/Station.astro";
import EmbedFigure from "../../components/ds/EmbedFigure.astro";
import CodeListing from "../../components/ds/CodeListing.astro";

// ── Case-study config (ported from the template's renderVals / props) ──
const githubUrl = "https://github.com/Ilgneous";
const videoUrl = "#";
const steeringWeight = "~480 g"; // placeholder — update with the real printed weight

const tags = ["C", "CAN bus", "TM4C123", "Embedded firmware", "OnShape", "PCB design", "Raspberry Pi 5", "Real-time graphics"];

const heroMeta = [
  { key: "Role", val: "Mechanical Design Lead · Comms Protocols" },
  { key: "Timeline", val: "Apr–May 2026 · 6 weeks" },
  { key: "Context", val: "Passion project · FSAE-inspired" },
  { key: "Stack", val: "C · OnShape · RPi 5 · Python" },
];

// hero signal-path legend — each row links to its chapter
const signalPath = [
  { n: "01", href: "#ch-input", title: "The Cockpit", note: "Input · CAD" },
  { n: "02", href: "#ch-sense", title: "The Board", note: "Sense · Custom PCBs" },
  { n: "03", href: "#ch-transmit", title: "The Bus", note: "Transmit · CAN firmware" },
  { n: "04", href: "#ch-render", title: "The Engine", note: "Render · from scratch" },
];

const componentMap = [
  { key: "MCU", val: "TM4C123 · bare-metal C" },
  { key: "SENSE", val: "Gyro · rotary encoders" },
  { key: "DRIVER I/O", val: "Buttons · switches · LCD · LED" },
  { key: "FEEDBACK", val: "Speaker" },
  { key: "BUS", val: "MCP2551 CAN transceiver" },
  { key: "POWER", val: "USB-C in" },
];

const canInit = [
  `<span class="com">// CAN0 @ 1 Mbps on the TM4C123</span>`,
  `<span class="kw">void</span> CAN0_Init(<span class="kw">void</span>) {`,
  `    SysCtlPeripheralEnable(SYSCTL_PERIPH_CAN0);`,
  `    GPIOPinConfigure(GPIO_PB4_CAN0RX);`,
  `    GPIOPinConfigure(GPIO_PB5_CAN0TX);`,
  `    GPIOPinTypeCAN(GPIO_PORTB_BASE, GPIO_PIN_4 | GPIO_PIN_5);`,
  ``,
  `    CANInit(CAN0_BASE);`,
  `    CANBitRateSet(CAN0_BASE, SysCtlClockGet(), <span class="num">1000000</span>);  <span class="com">// 1 Mbps</span>`,
  `    CANEnable(CAN0_BASE);`,
  `}`,
];

const bringup = [
  `<span class="com">// order matters: the gyro settles before the bus</span>`,
  `<span class="kw">void</span> system_bringup(<span class="kw">void</span>) {`,
  `    imu_init(&lsm6ds3);  <span class="com">// I2C + gyro FIRST</span>`,
  `    <span class="kw">while</span> (!imu_ready(&lsm6ds3));  <span class="com">// let it stop chattering</span>`,
  ``,
  `    CAN0_Init();  <span class="com">// now the bus comes up clean</span>`,
  `    can_set_nonblocking(<span class="kw">true</span>);  <span class="com">// 2 wheels <-> engine, no stalls</span>`,
  `}`,
];

const results = [
  { value: "1", unit: " Mbps", label: "CAN baud — instant steering feedback", accent: true },
  { value: "2", label: "Players racing in real time" },
  { value: "6", unit: " wk", label: "Concept to playable build" },
  { value: "<$100", label: "Total project budget" },
];

const phases = [
  { chip: "SHIPPED", title: "Playable v1", detail: "Two-player, real-time racing on procedurally generated maps.", state: "done" },
  { chip: "NEXT", title: "Higher-resolution inputs", detail: "Swap encoders for rotary potentiometers — finer pedal & steering angle.", state: "current" },
  { chip: "NEXT", title: "Richer gameplay", detail: "More map variability and a tighter, more responsive driving feel.", state: "target" },
  { chip: "NEXT", title: "Graphics pass", detail: "Higher visual quality while holding real-time render speed.", state: "target" },
];

const navLinks = [
  { href: "#ch-input", label: "Cockpit" },
  { href: "#ch-sense", label: "Boards" },
  { href: "#ch-transmit", label: "Firmware" },
  { href: "#results", label: "Telemetry" },
];
---

<Base
  title="Project Lykos — Case Study · Ilgneous"
  description="An embedded two-player racing simulator built from the silicon up — CAN firmware at 1 Mbps, custom PCBs, hand-built cockpits, and a from-scratch renderer, in six weeks under $100."
  navLinks={navLinks}
  ctaHref="/"
  ctaLabel="← All work"
>
  <!-- ── HERO ─────────────────────────────────────────────────────────── -->
  <section class="hero">
    <div class="hero__grid blueprint" aria-hidden="true"></div>
    <div class="hero__spotlight" aria-hidden="true"></div>

    <div class="hero__inner container">
      <div>
        <div class="hero__badges">
          <Eyebrow color="accent">Case file · Lykos</Eyebrow>
          <StatusBadge status="nominal">Shipped</StatusBadge>
        </div>
        <div class="hero__codename">CODENAME · LYKOS &nbsp;//&nbsp; EMBEDDED RACING SIMULATOR</div>
        <h1 class="hero__title">Project&nbsp;Lykos</h1>
        <p class="hero__lead">
          Two drivers. Two hand-built cockpits. One wire running a million bits a second between
          them — and a racing world drawn from scratch on the other side. This is the story of that
          signal, from the moment a hand turns the wheel to the frame that hits the screen.
        </p>

        <div class="meta-grid">
          {heroMeta.map((m) => (
            <div class="meta-cell">
              <div class="meta-cell__key">{m.key}</div>
              <div class="meta-cell__val">{m.val}</div>
            </div>
          ))}
        </div>

        <div class="hero__actions">
          <Button variant="primary" size="lg" href={githubUrl}>View the code →</Button>
          <Button variant="ghost" size="lg" href={videoUrl}>Watch the race</Button>
        </div>
      </div>

      <!-- signal-path legend -->
      <Panel reticle meta="SIGNAL PATH" padding="24px">
        <div class="legend__label">Follow the data</div>
        <div class="legend__intro">Each chapter is a station along the wire.</div>
        {signalPath.map((s, i) => (
          <a href={s.href} class:list={["legend__row", "legend__row--link", i === signalPath.length - 1 && "legend__row--last"]}>
            <span class="legend__n">{s.n}</span>
            <span class="legend__detail">
              <span class="legend__title">{s.title}</span>
              <span class="legend__note">{s.note}</span>
            </span>
          </a>
        ))}
      </Panel>
    </div>

    <div class="hero__builtwith container">
      <span class="hero__builtwith-label">Built with ·</span>
      {tags.map((t) => <Tag>{t}</Tag>)}
    </div>
  </section>

  <!-- ── PROLOGUE ─────────────────────────────────────────────────────── -->
  <section class="section">
    <div class="measure">
      <SectionDivider />
      <div class="problem">
        <div class="problem__aside">
          <div class="problem__station">Station 00</div>
          <h2 class="problem__title">The Premise</h2>
        </div>
        <div>
          <p class="problem__lead">
            I wanted to find out whether two people could really <span class="ink">race each other</span>
            on hardware I'd built myself — physics that felt honest, steering that felt instant, and a
            world generated fresh every run.
          </p>
          <p class="problem__body">
            The spark was FSAE — a prototype rig that could one day inform real driver-feel work. But the
            honest motivation was simpler: I wanted to build something genuinely fun, from the silicon up,
            and understand every layer in between. No game engine off the shelf. No dev board doing the hard
            part. Six weeks, under a hundred dollars, and a hard rule — if it moved data, I wrote it.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- ── CH 01 · INPUT ────────────────────────────────────────────────── -->
  <section id="ch-input" class="section">
    <div class="measure">
      <SectionDivider />
      <Station station="Station 01 · Input" title="The Cockpit">
        <p class="station__lead">
          Where a human hand becomes a number. Everything downstream is just this moment, faithfully relayed.
        </p>

        <div class="split">
          <div>
            <p class="prose">
              The wheel had to feel like a wheel — and come apart in seconds. I designed a
              <span class="ink"> detachable steering column</span> in OnShape so the whole rig stayed light,
              packable, and serviceable, with a gyroscope riding behind the hub to read rotation directly.
            </p>
            <p class="prose">
              Every part was shaped to print clean and assemble without a jig — because "under $100" only
              works if the fabrication is a 3D printer and a patient evening.
            </p>
          </div>
          <EmbedFigure
            kicker="EMBED · CAD RENDER"
            title="Steering-wheel assembly"
            subtitle="OnShape · isometric + exploded view"
            fig="FIG.01"
            ratio="4 / 3"
          />
        </div>

        <div class="split split--center split--flip">
          <EmbedFigure
            kicker="EMBED · CAD RENDER"
            title="Adjustable pedal box"
            subtitle="OnShape · brake + throttle, exploded view"
            fig="FIG.02"
            ratio="4 / 3"
          />
          <div>
            <p class="prose">
              The pedals were the fussiest mechanical problem. Drivers disagree about brake angle and how
              hard a throttle should fight back, so the box had to be <span class="ink">adjustable</span> —
              pedal angle, travel, and resistance all tunable.
            </p>
            <p class="prose">
              I constrained the geometry <span class="ink">one degree of freedom at a time</span>, locking
              each axis only once it behaved, so adjustability never collapsed into a wobbly mess. The result
              holds firm under a hard stomp and still prints in parts that snap together.
            </p>
          </div>
        </div>

        <div class="decision">
          <Panel accentLeft meta="DECISION · STEERING SENSE" padding="22px 24px">
            <div class="decision__kicker">Why a fixed-range IMU</div>
            <h3 class="decision__title">Adafruit LSM6DS3TR-C over a raw-gyro pipeline</h3>
            <div class="decision__verdict">
              <span class="decision__pick">LSM6DS3TR-C</span>
              <span class="decision__vs">vs raw-gyro + Kalman filter</span>
            </div>
            <p class="decision__body">
              It reads steering angle accurately with a driver simple enough to trust on day one. The trade:
              its range caps turning at <span class="ink">−90° to +90°</span> — but skipping raw-gyro
              integration and a stability filter bought back days I owed to writing the engine from scratch.
            </p>
          </Panel>
        </div>
      </Station>
    </div>
  </section>

  <!-- ── CH 02 · SENSE ────────────────────────────────────────────────── -->
  <section id="ch-sense" class="section">
    <div class="measure">
      <Station station="Station 02 · Sense" title="The Board">
        <p class="station__lead">
          A nervous system etched in copper. Each wheel carries its own brain, and turns motion into bytes.
        </p>

        <div class="split">
          <div>
            <p class="prose">
              Behind every wheel sits a custom PCB built around a <span class="ink">TM4C123</span>. I laid
              out the whole board: the gyroscope, rotary encoders, buttons and switches for the driver, an
              LCD and status LED, a speaker for feedback, USB-C power in, and the CAN transceiver out.
            </p>
            <p class="prose">
              It's the translation layer — analog twists and presses in, clean digital frames out. Getting
              the footprints and routing right here is what let the firmware upstairs stay simple.
            </p>
          </div>
          <EmbedFigure
            kicker="EMBED · PCB IMAGE"
            title="Steering-controller PCB"
            subtitle="Layout / Gerber top — annotate the blocks"
            fig="FIG.03"
            ratio="4 / 3"
          />
        </div>

        <div class="cmap">
          {componentMap.map((c) => (
            <div class="cmap__cell">
              <span class="cmap__key">{c.key}</span>
              <div class="cmap__val">{c.val}</div>
            </div>
          ))}
        </div>

        <div class="decision">
          <Panel accentLeft meta="DECISION · POWER" padding="22px 24px">
            <div class="decision__kicker">Tethered, but trustworthy</div>
            <h3 class="decision__title">USB-C over an onboard battery</h3>
            <div class="decision__verdict">
              <span class="decision__pick">USB-C</span>
              <span class="decision__vs">vs battery-powered</span>
            </div>
            <p class="decision__body">
              Battery meant freedom to roam but a real time-cost and finite runtime mid-race. USB-C gave the
              most reliable, repeatable delivery for demos — and a power bank drops in the moment we ever want
              to cut the cord.
            </p>
          </Panel>
        </div>
      </Station>
    </div>
  </section>

  <!-- ── CH 03 · TRANSMIT ─────────────────────────────────────────────── -->
  <section id="ch-transmit" class="section">
    <div class="measure">
      <Station station="Station 03 · Transmit" title="The Bus">
        <p class="station__lead">
          One pair of wires. A million bits a second. The moment steering becomes a shared truth.
        </p>

        <p class="prose prose--wide prose--gap">
          Two cockpits and a central game engine all need to talk at once, fast, without ever blocking each
          other. So I wrote <span class="ink">CAN drivers from the register up</span>, ran the bus at
          <span class="ink"> 1 Mbps</span>, and built non-blocking three-way communication between both
          steering controllers and the engine through an MCP2551 transceiver.
        </p>

        <div class="decision">
          <Panel accentLeft meta="DECISION · PROTOCOL" padding="22px 24px">
            <div class="decision__kicker">The first real fork in the road</div>
            <h3 class="decision__title">CAN over SPI, I²C, or an ESP32 link</h3>
            <div class="decision__verdict">
              <span class="decision__pick">CAN</span>
              <span class="decision__vs">vs SPI · I²C · ESP32</span>
            </div>
            <p class="decision__body">
              I needed fast, reliable comms over a harness long enough to span two seats. CAN's differential
              signalling and built-in arbitration shrugs off the electrical noise of a desk full of motors and
              wires. The trade: less raw write-speed flexibility — paid back many times over in data integrity
              and deterministic behaviour when the bus is busy.
            </p>
          </Panel>
        </div>

        <div class="listing">
          <CodeListing
            file="can_driver.c"
            listing="LST.01 · C"
            lines={canInit}
            caption="Replace with your actual driver excerpt — bit-timing + transceiver bring-up."
          />
        </div>

        <!-- war story -->
        <div class="warstory">
          <div class="warstory__head">
            <Eyebrow color="accent">Roadblock</Eyebrow>
            <span class="chip-resolved">
              <span class="chip-resolved__dot"></span>
              <span class="chip-resolved__text">Resolved · bus stable</span>
            </span>
          </div>
          <h3 class="warstory__title">The bus that lied</h3>
          <p class="prose prose--wide prose--gap">
            Then the bus started lying. Frames arrived intact one moment and corrupted the next — steering
            jitter, phantom inputs, game state drifting out from under both players. Nothing in the code looked
            wrong, which is the worst kind of bug.
          </p>

          <div class="split split--center">
            <p class="prose">
              So I stopped trusting the code and went to the wire. I put a
              <span class="ink"> logic analyzer on individual pins</span> and watched the transceiver lines in
              real time, hunting for the exact instant good data turned to garbage.
            </p>
            <EmbedFigure
              kicker="EMBED · CAPTURE"
              title="Logic-analyzer trace"
              subtitle="CANH / CANL — clean frames, post-fix"
              fig="FIG.04"
              ratio="16 / 10"
            />
          </div>

          <p class="prose prose--wide prose--gap">
            It was two faults wearing one mask. First, the physical connections were marginal — so I reworked
            them into <span class="ink">reliable, strain-tolerant joints</span>. Second, the gyroscope's
            bring-up was stepping on the CAN driver's initialization. Reordering the boot so the IMU
            <span class="ink"> settles before the bus comes up</span> let CAN initialize clean. The bus went
            quiet, then honest.
          </p>

          <div class="listing">
            <CodeListing
              file="system_bringup.c"
              listing="LST.02 · C"
              lines={bringup}
              caption="The fix that mattered most — init ordering, not init logic."
            />
          </div>
        </div>
      </Station>
    </div>
  </section>

  <!-- ── CH 04 · RENDER ───────────────────────────────────────────────── -->
  <section id="ch-render" class="section">
    <div class="measure">
      <Station station="Station 04 · Render" title="The Engine" fade>
        <p class="station__lead">
          Where the signal finally becomes a world — drawn from scratch, in real time.
        </p>

        <p class="prose prose--wide prose--gap">
          Frames land at the central TM4C, which runs the physics, collisions, game state, and a fresh
          procedurally generated track each round. It hands the result to a <span class="ink">Raspberry Pi 5</span>,
          which renders and drives two monitors — one view per driver, racing the same world in real time.
        </p>

        <div class="decision">
          <Panel accentLeft meta="DECISION · ENGINE" padding="22px 24px">
            <div class="decision__kicker">The most expensive, most rewarding call</div>
            <h3 class="decision__title">A from-scratch renderer over Unity</h3>
            <div class="decision__verdict">
              <span class="decision__pick">From scratch</span>
              <span class="decision__vs">vs Unity</span>
            </div>
            <p class="decision__body">
              I wrote the renderer myself — ray tracing included — for the learning, the full control, and the
              rendering-speed headroom real-time racing demands. The trade: less time for gameplay polish and
              per-frame visual fidelity. What it bought: a pipeline I understood completely, fast enough to put
              two cars on screen at once.
            </p>
          </Panel>
        </div>

        <div class="video">
          <EmbedFigure
            kicker="EMBED · GAMEPLAY VIDEO"
            title="Prototype · live multiplayer race"
            subtitle="Drop a clip or an embed link here"
            fig="FIG.05"
            ratio="16 / 9"
            video
          />
        </div>
      </Station>
    </div>
  </section>

  <!-- ── TELEMETRY / RESULTS ──────────────────────────────────────────── -->
  <section id="results" class="section">
    <div class="measure">
      <SectionDivider />
      <div class="results__head">
        <Eyebrow color="accent">Telemetry</Eyebrow>
        <h2 class="results__title">Signal, end to end</h2>
      </div>
      <div class="results__grid">
        {results.map((r) => (
          <div class="results__cell">
            <Kpi value={r.value} unit={r.unit} label={r.label} accent={r.accent} />
          </div>
        ))}
      </div>
      <p class="prose prose--wide prose--gap">
        The 1 Mbps bus made steering feel instant, the detachable wheel — roughly
        <span class="ink"> {steeringWeight}</span> printed — kept the rig light and serviceable, and the whole
        experience, hardware to engine, came together in a six-week sprint under budget.
      </p>
    </div>
  </section>

  <!-- ── NEXT STEPS ───────────────────────────────────────────────────── -->
  <section class="section">
    <div class="measure">
      <SectionDivider />
      <div class="next">
        <div>
          <Eyebrow color="accent">Next steps</Eyebrow>
          <h2 class="next__title">Lykos isn't finished</h2>
          <p class="next__body">
            Three more months of runway would go straight into feel and fidelity — finer input resolution,
            richer gameplay, and a graphics pass that never gives up real-time speed.
          </p>
        </div>
        <Panel meta="ROADMAP" padding="26px">
          <Eyebrow dot color="accent">Planned</Eyebrow>
          <div class="next__traj">
            <Trajectory phases={phases} />
          </div>
        </Panel>
      </div>
    </div>
  </section>

  <!-- ── CONTACT CTA ──────────────────────────────────────────────────── -->
  <section class="section section--cta">
    <div class="measure">
      <SectionDivider />
      <div class="cta">
        <div class="cta__spotlight" aria-hidden="true"></div>
        <div class="cta__left">
          <Eyebrow dot color="accent">Open channel</Eyebrow>
          <h2 class="cta__title">Want the deep dive on Lykos?</h2>
          <p class="cta__body">
            Happy to walk the firmware, the CAD, or the engine — wherever along the signal path you want to go.
          </p>
        </div>
        <div class="cta__actions">
          <Button variant="primary" size="lg" href={githubUrl}>View the code →</Button>
          <Button variant="ghost" size="lg" href="/">Back to portfolio</Button>
        </div>
      </div>
    </div>
  </section>
</Base>

<style>
  .container { max-width: var(--container); margin: 0 auto; }
  .measure { max-width: 1080px; margin: 0 auto; padding: 0 32px; }
  .section { padding: 8px 32px; }
  .section--cta { padding-top: 24px; }

  /* shared prose. .ink is :global because it also appears inside set:html
     (code listings) where Astro's scoped hash isn't applied. */
  :global(.ink) { color: var(--text-display); }
  .prose { font-size: 16px; line-height: 1.7; color: var(--text-secondary); margin: 0; }
  .prose + .prose { margin-top: 16px; }
  .prose--wide { max-width: 64ch; }
  .prose--gap { margin-top: 26px; }

  .split { display: grid; grid-template-columns: 1fr 1fr; gap: 32px; align-items: center; margin-top: 34px; }
  .split--center { align-items: center; margin-top: 26px; }

  /* ── HERO ── */
  .hero { position: relative; overflow: hidden; padding: 72px 32px 56px; }
  .hero__grid {
    position: absolute; inset: 0; pointer-events: none;
    -webkit-mask-image: radial-gradient(120% 92% at 50% 0%, #000 35%, transparent 80%);
    mask-image: radial-gradient(120% 92% at 50% 0%, #000 35%, transparent 80%);
  }
  .hero__spotlight { position: absolute; inset: 0; pointer-events: none; background: var(--spotlight-ember); }
  .hero__inner {
    position: relative;
    display: grid;
    grid-template-columns: 1.55fr 1fr;
    gap: 52px;
    align-items: start;
  }
  .hero__badges { display: flex; align-items: center; gap: 14px; flex-wrap: wrap; margin-bottom: 20px; }
  .hero__codename {
    font-family: var(--font-mono); font-size: 12px; letter-spacing: 0.18em;
    text-transform: uppercase; color: var(--text-faint); margin-bottom: 10px;
  }
  .hero__title {
    font-size: clamp(48px, 6.4vw, 92px); font-weight: 600; line-height: 0.92;
    letter-spacing: -0.03em; color: var(--text-display); margin: 0;
    font-feature-settings: var(--display-features);
  }
  .hero__lead {
    max-width: 50ch; margin-top: 22px; font-size: clamp(18px, 1.6vw, 21px);
    line-height: 1.5; color: var(--text-secondary);
  }
  .hero__actions { display: flex; gap: 14px; margin-top: 28px; flex-wrap: wrap; }

  .hero__builtwith {
    position: relative; margin-top: 34px;
    display: flex; flex-wrap: wrap; gap: 8px; align-items: center;
  }
  .hero__builtwith-label {
    font-family: var(--font-mono); font-size: 11px; letter-spacing: 0.14em;
    text-transform: uppercase; color: var(--text-faint); margin-right: 6px;
  }

  /* hero meta grid */
  .meta-grid {
    display: grid; grid-template-columns: repeat(2, minmax(0, 1fr)); gap: 1px;
    margin-top: 32px; background: var(--border); border: 1px solid var(--border);
    border-radius: var(--radius-md); overflow: hidden;
  }
  .meta-cell { background: var(--surface-raised); padding: 16px 18px; }
  .meta-cell__key {
    font-family: var(--font-mono); font-size: 10px; letter-spacing: 0.2em;
    text-transform: uppercase; color: var(--text-faint);
  }
  .meta-cell__val { font-size: 15px; color: var(--text-secondary); margin-top: 6px; line-height: 1.4; }

  /* signal-path legend (links) */
  .legend__label {
    font-family: var(--font-mono); font-size: 11px; letter-spacing: 0.18em;
    text-transform: uppercase; color: var(--text-faint); margin-bottom: 6px;
  }
  .legend__intro { font-size: 14px; line-height: 1.5; color: var(--text-muted); margin-bottom: 20px; }
  .legend__row {
    display: flex; align-items: center; gap: 14px; padding: 11px 0;
    border-top: 1px solid var(--hairline); text-decoration: none;
  }
