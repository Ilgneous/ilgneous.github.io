---
import Base from '../../layouts/Base.astro';
import SteeringField from '../../components/SteeringField.svelte';

const stats = [
  { n: '68%', k: 'mass reduction' },
  { n: 'CFRP', k: 'steering column' },
  { n: 'LPBF', k: 'metal printed gearboxes' },
  { n: '~6%', k: 'anti-Ackermann' },
];

const decisions = [
  {
    h: 'Steel column → carbon-fiber tube',
    p: 'The old steering column was a steel tube — heavy, and adding rotating inertia right where the driver feels it most. Switching to a multi-layer CFRP layup cut the mass dramatically while keeping torsional stiffness high, so steering feel got sharper, not vaguer. This single change drove most of the 68% reduction.',
  },
  {
    h: 'Double-U-joint → printed bevel gearboxes',
    p: 'Routing the column around the driver\'s legs used to mean a chain of universal joints, which introduced compliance and non-constant velocity through the steering motion. I replaced them with compact metal SLS-printed bevel gearboxes — fewer parts, tighter packaging in the nose cone, and a cleaner transmission of the driver\'s input.',
  },
  {
    h: 'KAZ rack → NARRco rack',
    p: 'Rack selection came down to a weighted decision matrix across mass, tolerance, ratio, and packaging. The lighter, tighter-tolerance NARRco rack won — less backlash at the wheel and a better fit within the bulkhead constraints.',
  },
  {
    h: 'Slight anti-Ackermann, on purpose',
    p: 'On a high-grip autocross car running real slip angles, perfect Ackermann isn\'t optimal — the heavily loaded outer tire wants a slightly larger angle. So the steering arm geometry was tuned for a modest anti-Ackermann, validated against bump-steer through full suspension travel so the toe stays honest over bumps.',
  },
];

const phases = [
  { n: '01', h: 'Requirements & concept', items: ['Define steering ratio, compliance, and ergonomics targets', 'Benchmark the previous steel-column / double-U-joint system', 'Map packaging limits inside the nose cone and bulkhead'] },
  { n: '02', h: 'Kinematics & vehicle dynamics', items: ['Compute the target anti-Ackermann percentage', 'Sweep tie-rod and upright geometry to minimize bump steer', 'Apply the Milliken Moment Method to balance understeer / oversteer'] },
  { n: '03', h: 'Mechanical redesign & analysis', items: ['Replace steel column with multi-layer CFRP tube', 'Design custom SLS-printed bevel gearboxes', 'FEA on housings, shafts, and the CFRP column for stiffness and safety factors'] },
  { n: '04', h: 'Fabrication & assembly', items: ['CNC-machine housings, mounts, and interfaces', 'Metal-print and post-process the bevel gearboxes', 'Lay up the CFRP column; build welding jigs; align the assembly centerline'] },
  { n: '05', h: 'Testing & validation', items: ['Measure gearbox lash, bearing preload, and column compliance', 'Validate Ackermann and bump-steer on the assembled chassis', 'Track-test steering effort, feel, and transient handling'] },
];
---

<Base title="FSAE Steering System — Sivan Syed" description="A carbon-fiber Formula SAE steering system, 68% lighter than its predecessor, with tuned anti-Ackermann geometry.">
  <article>
    <!-- HERO -->
    <header class="phero">
      <div class="wrap">
        <a href="/#work" class="back mono">← back to work</a>
        <div class="eyebrow mono">// CASE STUDY · MECHANICAL · 2025</div>
        <h1>FSAE Steering System</h1>
        <p class="sub">
          A complete redesign of a Formula SAE car's steering — from a heavy steel
          column to carbon fiber and custom-printed gearboxes, <strong>68% lighter</strong>
          and sharper in the driver's hands.
        </p>
        <SteeringField client:load />
        <p class="cap mono">FIG.01 — Interactive: move your cursor to steer. Outer wheel leads the inner — a slight anti-Ackermann split.</p>
      </div>
    </header>

    <!-- STATS -->
    <section class="wrap stats-wrap">
      <div class="stats">
        {stats.map((s) => (
          <div class="stat">
            <div class="stat-n">{s.n}</div>
            <div class="stat-k mono">{s.k}</div>
          </div>
        ))}
      </div>
    </section>

    <!-- NARRATIVE -->
    <section class="wrap prose">
      <div class="eyebrow mono">// THE BRIEF</div>
      <p class="big">
        Steering is the one system the driver touches every second of every lap.
        It has to be light, stiff, and honest — and the car it came on was none of those.
      </p>
      <p>
        The previous design used a steel column and a chain of universal joints to route
        the wheel around the driver's legs. It worked, but it was heavy, it flexed under load,
        and the U-joints made the steering feel slightly different depending on where in the
        rotation you were. The goal was a system that disappeared — that let the driver feel
        the front tires directly, with as little mass and compliance in between as possible.
      </p>
    </section>

    <!-- KEY DECISIONS -->
    <section class="wrap">
      <div class="eyebrow mono">// KEY DECISIONS</div>
      <div class="decisions">
        {decisions.map((d) => (
          <div class="decision">
            <h3>{d.h}</h3>
            <p>{d.p}</p>
          </div>
        ))}
      </div>
    </section>

    <!-- PROCESS (genuine sequence → numbered) -->
    <section class="wrap proc-wrap">
      <div class="eyebrow mono">// HOW IT CAME TOGETHER</div>
      <ol class="phases">
        {phases.map((ph) => (
          <li class="phase">
            <div class="phase-n mono">{ph.n}</div>
            <div class="phase-body">
              <h3>{ph.h}</h3>
              <ul>
                {ph.items.map((it) => <li>{it}</li>)}
              </ul>
            </div>
          </li>
        ))}
      </ol>
    </section>

    <!-- TOOLS -->
    <section class="wrap tools-wrap">
      <div class="eyebrow mono">// TOOLS & METHODS</div>
      <div class="tools">
        <div class="tool-group">
          <span class="tg-k mono">Design</span>
          <span class="tg-v">SolidWorks · full-system CAD · steering kinematics</span>
        </div>
        <div class="tool-group">
          <span class="tg-k mono">Analysis</span>
          <span class="tg-v">FEA on housings, shafts, CFRP column</span>
        </div>
        <div class="tool-group">
          <span class="tg-k mono">Fabrication</span>
          <span class="tg-v">Carbon-fiber layup · metal SLS · CNC · TIG fixtures</span>
        </div>
        <div class="tool-group">
          <span class="tg-k mono">Dynamics</span>
          <span class="tg-v">Milliken Moment Method · Ackermann · bump-steer</span>
        </div>
      </div>
    </section>

    <!-- NEXT -->
    <section class="wrap next-wrap">
      <a href="/#work" class="next">
        <span class="mono dim">← all work</span>
        <span class="next-t">See the other projects</span>
      </a>
    </section>
  </article>

  <style>
    .wrap { max-width: 1000px; margin: 0 auto; padding: 0 clamp(20px, 5vw, 64px); }
    .mono { font-family: var(--font-mono); }
    .eyebrow {
      font-size: 12px;
      letter-spacing: 0.16em;
      color: var(--color-blueprint);
      margin-bottom: 24px;
    }

    /* HERO */
    .phero { padding: clamp(32px, 6vh, 64px) 0 clamp(40px, 6vh, 70px); text-align: center; }
    .phero .wrap { display: flex; flex-direction: column; align-items: center; }
    .back {
      align-self: flex-start;
      font-size: 12px;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      color: var(--color-paper-dim);
      text-decoration: none;
      margin-bottom: 40px;
      transition: color 0.2s;
    }
    .back:hover { color: var(--color-torque); }
    h1 {
      font-family: var(--font-display);
      font-weight: 600;
      font-size: clamp(36px, 6vw, 66px);
      line-height: 1.02;
      letter-spacing: -0.02em;
      margin: 0;
      max-width: 14ch;
    }
    .sub {
      margin: 22px 0 0;
      max-width: 52ch;
      font-size: 18px;
      line-height: 1.6;
      color: #D8D5CD;
    }
    .sub strong { color: var(--color-paper); font-weight: 600; }
    :global(.phero .panel) { margin-top: clamp(32px, 5vh, 50px); }
    .cap {
      margin-top: 16px;
      font-size: 11px;
      letter-spacing: 0.06em;
      color: var(--color-paper-dim);
      max-width: 54ch;
      line-height: 1.6;
    }

    /* STATS */
    .stats-wrap { margin-top: clamp(20px, 4vh, 40px); }
    .stats {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 1px;
      background: var(--color-neutral-line);
      border: 1px solid var(--color-neutral-line);
      border-radius: 3px;
      overflow: hidden;
    }
    .stat { background: var(--color-graphite); padding: 24px 20px; }
    .stat-n {
      font-family: var(--font-display);
      font-weight: 600;
      font-size: clamp(26px, 3.4vw, 36px);
      color: var(--color-torque);
      letter-spacing: -0.01em;
    }
    .stat-k { font-size: 10.5px; letter-spacing: 0.1em; text-transform: uppercase; color: var(--color-paper-dim); margin-top: 6px; }
    @media (max-width: 620px) { .stats { grid-template-columns: repeat(2, 1fr); } }

    /* PROSE */
    .prose { margin-top: clamp(60px, 10vh, 110px); }
    .prose .big {
      font-family: var(--font-display);
      font-weight: 500;
      font-size: clamp(22px, 2.8vw, 30px);
      line-height: 1.34;
      letter-spacing: -0.01em;
      margin: 0 0 28px;
      max-width: 30ch;
    }
    .prose p:not(.big) { font-size: 17px; line-height: 1.75; color: #C9C6BE; max-width: 64ch; margin: 0; }

    /* DECISIONS */
    section + section { margin-top: clamp(56px, 9vh, 100px); }
    .decisions { display: grid; grid-template-columns: 1fr 1fr; gap: 1px; background: var(--color-neutral-line); border: 1px solid var(--color-neutral-line); border-radius: 3px; overflow: hidden; }
    .decision { background: var(--color-graphite); padding: clamp(24px, 3vw, 36px); }
    .decision h3 {
      font-family: var(--font-display);
      font-weight: 600;
      font-size: clamp(18px, 2vw, 22px);
      letter-spacing: -0.01em;
      margin: 0 0 14px;
      color: var(--color-paper);
    }
    .decision p { font-size: 15px; line-height: 1.65; color: #BEBBB3; margin: 0; }
    @media (max-width: 720px) { .decisions { grid-template-columns: 1fr; } }

    /* PHASES */
    .phases { list-style: none; margin: 0; padding: 0; border-top: 1px solid var(--color-neutral-line); }
    .phase {
      display: grid;
      grid-template-columns: auto 1fr;
      gap: clamp(18px, 3vw, 40px);
      padding: clamp(22px, 3vw, 32px) 0;
      border-bottom: 1px solid var(--color-neutral-line);
    }
    .phase-n { color: var(--color-blueprint); font-size: 14px; padding-top: 4px; }
    .phase-body h3 {
      font-family: var(--font-display);
      font-weight: 600;
      font-size: clamp(19px, 2.2vw, 24px);
      letter-spacing: -0.01em;
      margin: 0 0 14px;
    }
    .phase-body ul { margin: 0; padding-left: 18px; }
    .phase-body li { font-size: 15px; line-height: 1.7; color: #BEBBB3; margin-bottom: 4px; }

    /* TOOLS */
    .tools { display: grid; grid-template-columns: 1fr 1fr; gap: 20px 48px; }
    .tool-group { border-top: 1px solid var(--color-neutral-line); padding-top: 14px; }
    .tg-k { display: block; font-size: 11px; letter-spacing: 0.12em; text-transform: uppercase; color: var(--color-blueprint); margin-bottom: 8px; }
    .tg-v { font-size: 15px; line-height: 1.5; color: #C9C6BE; }
    @media (max-width: 620px) { .tools { grid-template-columns: 1fr; } }

    /* NEXT */
    .next-wrap { margin-top: clamp(56px, 9vh, 100px); }
    .next {
      display: flex;
      flex-direction: column;
      gap: 8px;
      padding: clamp(28px, 4vw, 44px);
      border: 1px solid var(--color-neutral-line);
      border-radius: 3px;
      text-decoration: none;
      transition: border-color 0.25s, background 0.25s;
    }
    .next:hover { border-color: var(--color-torque); background: var(--color-graphite-2); }
    .next .dim { font-size: 12px; letter-spacing: 0.08em; text-transform: uppercase; color: var(--color-paper-dim); }
    .next-t {
      font-family: var(--font-display);
      font-weight: 600;
      font-size: clamp(22px, 3vw, 30px);
      letter-spacing: -0.01em;
    }
    .next:hover .next-t { color: var(--color-torque); }
  </style>
</Base>
