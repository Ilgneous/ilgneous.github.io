---
import Base from '../layouts/Base.astro';
import SteeringField from '../components/SteeringField.svelte';
import { getCollection } from 'astro:content';

const B = import.meta.env.BASE_URL;

const all = await getCollection('projects');
all.sort((a, b) => {
  const ao = a.data.order ?? 999;
  const bo = b.data.order ?? 999;
  if (ao !== bo) return ao - bo;
  return (b.data.date ?? '').localeCompare(a.data.date ?? '');
});

const statBySlug: Record<string, { stat: string; statLabel: string }> = {
  'fsae-steering-system': { stat: '68%', statLabel: 'lighter' },
  'boost-converter': { stat: 'SMPS', statLabel: 'from scratch' },
};

const dedicatedPages: Record<string, string> = {
  'fsae-steering-system': `${B}work/fsae`,
};

const fallbackStat: { stat: string | null; statLabel: string | null } = { stat: null, statLabel: null };

const projects = all.map((p, i) => ({
  slug: p.slug,
  index: String(i + 1).padStart(2, '0'),
  title: p.data.title,
  blurb: p.data.summary,
  tags: p.data.tech.slice(0, 4),
  href: dedicatedPages[p.slug] ?? `${B}projects/${p.slug}`,
  isDedicated: Boolean(dedicatedPages[p.slug]),
  ...(statBySlug[p.slug] ?? fallbackStat),
}));
---

<Base>
  <section class="hero">
    <div class="hero-inner">
      <div class="wave mono">👋 &nbsp;hello there</div>
      <h1>Hi, I'm <span class="nm">Sivan Syed</span> — physics &amp; ECE at UT Austin.</h1>
      <p class="lede">
        Here's a peek into my <span class="dungeon">dungeon</span>: robots, circuits,
        and the occasional carbon-fiber experiment. Have a look around.
      </p>
      <SteeringField client:load />
      <a href="#work" class="scroll mono">scroll to explore</a>
    </div>
  </section>

  <section class="band" id="about">
    <div class="wrap">
      <div class="eyebrow mono">// WHAT I DO</div>
      <div class="cols">
        <p class="big">
          I like problems that live between disciplines — where the physics, the
          electronics, and the mechanical design all have to agree before anything works.
        </p>
        <p class="small">
          Most of what I build starts on paper: a free-body diagram, a control loop,
          a circuit. Then it becomes hardware, and the interesting part begins — the
          gap between what the model says and what the bench measures. These are a few
          of the projects where that gap taught me the most.
        </p>
      </div>
    </div>
  </section>

  <section class="work" id="work">
    <div class="wrap">
      <div class="eyebrow mono">// SELECTED WORK</div>
      <ul class="proj-list">
        {projects.map((p) => (
          <li class="proj">
            <a href={p.href} class="proj-link">
              <span class="proj-index mono">{p.index}</span>
              <span class="proj-main">
                <span class="proj-head">
                  <span class="proj-title">{p.title}</span>
                  {p.isDedicated && <span class="badge mono">case study</span>}
                </span>
                <span class="proj-blurb">{p.blurb}</span>
                <span class="proj-tags">
                  {p.tags.map((t) => <span class="tag mono">{t}</span>)}
                </span>
              </span>
              {p.stat && (
                <span class="proj-stat">
                  <span class="proj-stat-n">{p.stat}</span>
                  <span class="proj-stat-k mono">{p.statLabel}</span>
                </span>
              )}
            </a>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <style>
    .wrap { max-width: 1180px; margin: 0 auto; padding: 0 clamp(20px, 5vw, 64px); }
    .eyebrow { font-size: 12px; letter-spacing: 0.16em; color: var(--color-blueprint); margin-bottom: 28px; }
    .mono { font-family: var(--font-mono); }
    .hero { min-height: calc(100vh - 64px); display: flex; align-items: center; justify-content: center; }
    .hero-inner { max-width: 1180px; width: 100%; padding: clamp(40px, 7vh, 80px) clamp(20px, 5vw, 64px); display: flex; flex-direction: column; align-items: center; text-align: center; }
    .wave { font-size: 13px; letter-spacing: 0.16em; text-transform: uppercase; color: var(--color-blueprint); margin-bottom: 22px; }
    h1 { font-family: var(--font-display); font-weight: 600; letter-spacing: -0.02em; font-size: clamp(32px, 5.4vw, 60px); line-height: 1.04; max-width: 16ch; margin: 0; }
    h1 .nm { color: var(--color-torque); }
    .lede { margin: 24px 0 0; max-width: 50ch; font-size: 18px; line-height: 1.6; color: #D8D5CD; }
    .dungeon { color: var(--color-paper); font-weight: 600; border-bottom: 1.5px solid var(--color-torque); padding-bottom: 1px; }
    :global(.hero-inner .panel) { margin-top: clamp(34px, 5vh, 54px); }
    .scroll { margin-top: 30px; font-size: 11px; letter-spacing: 0.14em; text-transform: uppercase; color: var(--color-paper-dim); text-decoration: none; display: inline-flex; align-items: center; gap: 9px; transition: color 0.2s; }
    .scroll::after { content: "↓"; color: var(--color-torque); }
    .scroll:hover { color: var(--color-paper); }
    .band { padding: clamp(60px, 10vh, 110px) 0; border-top: 1px solid var(--color-neutral-line); }
    .cols { display: grid; grid-template-columns: 1.2fr 1fr; gap: clamp(32px, 6vw, 80px); align-items: start; }
    .big { font-family: var(--font-display); font-weight: 500; font-size: clamp(22px, 2.6vw, 30px); line-height: 1.32; margin: 0; letter-spacing: -0.01em; }
    .small { font-size: 16px; line-height: 1.7; color: #C9C6BE; margin: 0; padding-top: 6px; }
    @media (max-width: 760px) { .cols { grid-template-columns: 1fr; gap: 24px; } }
    .work { padding-bottom: clamp(20px, 4vh, 40px); }
    .proj-list { list-style: none; margin: 0; padding: 0; border-top: 1px solid var(--color-neutral-line); }
    .proj { border-bottom: 1px solid var(--color-neutral-line); }
    .proj-link { display: grid; grid-template-columns: auto 1fr auto; gap: clamp(16px, 3vw, 40px); align-items: start; padding: clamp(24px, 3.5vw, 38px) 8px; text-decoration: none; transition: background 0.25s, padding-left 0.25s; }
    .proj-link:hover { background: var(--color-graphite-2); padding-left: 20px; }
    .proj-index { color: var(--color-blueprint); font-size: 13px; padding-top: 6px; }
    .proj-head { display: flex; align-items: baseline; gap: 14px; flex-wrap: wrap; }
    .proj-title { font-family: var(--font-display); font-weight: 600; font-size: clamp(22px, 3vw, 32px); letter-spacing: -0.01em; }
    .proj-link:hover .proj-title { color: var(--color-torque); }
    .badge { font-size: 10px; letter-spacing: 0.1em; text-transform: uppercase; color: var(--color-blueprint); border: 1px solid color-mix(in srgb, var(--color-blueprint) 40%, transparent); padding: 3px 8px; border-radius: 2px; }
    .proj-blurb { display: block; margin-top: 12px; max-width: 60ch; font-size: 15.5px; line-height: 1.6; color: #C2BFB7; }
    .proj-tags { display: flex; flex-wrap: wrap; gap: 8px; margin-top: 16px; }
    .proj-tags .tag { font-size: 10.5px; letter-spacing: 0.06em; text-transform: uppercase; color: var(--color-paper-dim); border: 1px solid var(--color-neutral-line); padding: 4px 9px; border-radius: 2px; }
    .proj-stat { text-align: right; padding-top: 4px; white-space: nowrap; }
    .proj-stat-n { display: block; font-family: var(--font-display); font-weight: 600; font-size: clamp(24px, 3vw, 34px); color: var(--color-torque); letter-spacing: -0.01em; }
    .proj-stat-k { display: block; font-size: 10.5px; letter-spacing: 0.08em; text-transform: uppercase; color: var(--color-paper-dim); margin-top: 2px; }
    @media (max-width: 640px) { .proj-link { grid-template-columns: auto 1fr; } .proj-stat { grid-column: 2; text-align: left; margin-top: 14px; } .proj-stat-n { font-size: 22px; } }
  </style>
</Base>
