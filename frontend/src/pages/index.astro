<section class="section">
  <header class="mb-8 sm:mb-10">
    <p class="eyebrow-mono">// 04 &mdash; ACADEMIC RECORD</p>
    <div class="flex items-end justify-between flex-wrap gap-3 mt-3">
      <h2 class="display text-3xl sm:text-4xl font-bold text-zinc-100">
        Coursework
      </h2>
      <p class="font-mono text-[11px] uppercase tracking-[0.18em] text-zinc-500">
        {totalCourses} courses &middot; {deptsRepresented} departments
      </p>
    </div>
    <p class="mt-3 max-w-2xl text-[15px] sm:text-base leading-relaxed text-zinc-300/80">
      The coursework that grounds the projects. Departments are color-coded;
      depth markers indicate intro, core, or advanced/graduate-level material.
    </p>
  </header>
 
  {/* Department legend */}
  <div class="dept-legend mb-6">
    {Object.entries(deptInfo).map(([key, info]) => (
      deptCounts[key] ? (
        <span class={`dept-tag ${info.classes}`}>
          <span class="dept-dot"></span>
          {info.label}
          <span class="dept-count">{deptCounts[key]}</span>
        </span>
      ) : null
    ))}
  </div>
 
  {/* Transcript */}
  <div class="transcript">
    {terms.map((term) => (
      <div class={`term term-${term.status}`}>
        <header class="term-head">
          <p class="font-mono text-[11px] uppercase tracking-[0.18em]">
            <span class="term-label">{term.label}</span>
            <span class="term-status">[{term.status.toUpperCase()}]</span>
          </p>
          <p class="font-mono text-[10px] text-zinc-600">
            {term.courses.length} courses
          </p>
        </header>
 
        <ul class="course-list">
          {term.courses.map((c) => (
            <li class={`course ${deptInfo[c.dept].classes}`}>
              <span class="course-code">{c.code}</span>
              <div class="course-main">
                <span class="course-title">{c.title}</span>
                <div class="course-meta">
                  {c.honors && <span class="course-flag">HON</span>}
                  {c.depth && (
                    <span class="course-depth" title={`Depth: ${c.depth}/3`}>
                      {Array.from({ length: 3 }).map((_, i) => (
                        <span class={`depth-bar ${i < c.depth! ? "on" : ""}`}></span>
                      ))}
                    </span>
                  )}
                </div>
              </div>
            </li>
          ))}
        </ul>
      </div>
    ))}
  </div>
</section>


