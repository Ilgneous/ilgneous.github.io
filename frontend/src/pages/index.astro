---
import Base from "../layouts/Base.astro";
import Eyebrow from "../components/ds/Eyebrow.astro";
import Button from "../components/ds/Button.astro";
import Panel from "../components/ds/Panel.astro";
import Kpi from "../components/ds/Kpi.astro";
import SectionDivider from "../components/ds/SectionDivider.astro";
import Tag from "../components/ds/Tag.astro";
import Trajectory from "../components/ds/Trajectory.astro";
import FeaturedProject from "../components/ds/FeaturedProject.astro";
import ProjectCard from "../components/ds/ProjectCard.astro";

// ────────────────────────────────────────────────────────────────────────────
// CONTENT — ported from the PortfolioSite template's renderVals().
// These are placeholder/real-ish entries. When you migrate to your content
// collection, replace `featured` and `projects` with getCollection("projects")
// output and map the frontmatter into these same shapes.
// ────────────────────────────────────────────────────────────────────────────
const base = "/assets/projects/";

const featured = [
  {
    index: "F1", codename: "Project Lykos", title: "Multiplayer Racing Simulator",
    domain: "Embedded · Sim", year: "2026", status: "nominal", flip: false, image: null,
    href: "/work/lykos",
    summary: "An embedded two-player racing sim built from the silicon up — CAN firmware at 1 Mbps, custom PCBs, hand-built cockpits, and a from-scratch renderer, in six weeks under $100.",
    highlight: ["1 Mbps", "from-scratch renderer"],
    tech: ["C", "CAN bus", "TM4C123", "OnShape", "Raspberry Pi 5"],
    metrics: [
      { value: "2", label: "Players", accent: true },
      { value: "1", unit: "Mbps", label: "CAN baud" },
      { value: "<$100", label: "Budget" },
    ],
  },
  {
    index: "F2", codename: "Project RipWing", title: "Safety-Critical UAV Flight Controller",
    domain: "Aerospace · Embedded", year: "2026", status: "active", flip: true, image: null,
    href: "/work/ripwing",
    summary: "A custom flight controller that catches failure before it crashes — RTOS-isolated stabilization plus an edge TinyML anomaly pipeline that cut simulated crashes by 92%.",
    highlight: ["TinyML", "92%"],
    tech: ["Rust", "C", "FreeRTOS", "STM32", "TinyML"],
    metrics: [
      { value: "92", unit: "%", label: "Crash reduction", accent: true },
      { value: "20", unit: "ms", label: "Fault reaction" },
      { value: "±2", unit: "µs", label: "Loop jitter" },
    ],
  },
  {
    index: "F3", codename: "Longhorn Racing", title: "FSAE Steering & Vehicle Dynamics",
    domain: "Mechanical · Dynamics", year: "2025", status: "nominal", flip: false, image: base + "IRPCB.png",
    href: "/work/fsae",
    summary: "A steering rebuild 68% lighter and sharper in the hands — carbon column, printed bevel gearboxes, deliberate anti-Ackermann — that grew into a full-vehicle kinematic and compliance model.",
    highlight: ["68% lighter", "full-vehicle"],
    tech: ["SolidWorks", "FEA", "Carbon Fiber", "Python", "Vehicle Dynamics"],
    metrics: [
      { value: "68", unit: "%", label: "Mass cut", accent: true },
      { value: "CFRP", label: "Column" },
      { value: "~6", unit: "%", label: "Anti-Ackermann" },
    ],
  },
] as const;

const projects = [
  {
    index: "02", title: "Ping-Pong Balancer", status: "active", href: "#",
    summary: "A 3-DoF platform that tracks and stabilizes a ball in real time via OpenCV + IK.",
    highlight: "real time", image: null,
    tech: ["OpenCV", "Python", "Dynamixel", "Controls", "Raspberry Pi 5"],
  },
  {
    index: "12", title: "Transformer Model for PSD", status: null, href: "#",
    summary: "Pulse-shape discrimination for radioactive sources — >98% classification accuracy.",
    highlight: ">98% classification accuracy", image: base + "TransformerModel.png",
    tech: ["Transformer", "PyTorch", "Signal Processing", "Python"],
  },
  {
    index: "14", title: "Surrogate ML for MHD", status: null, href: "#",
    summary: "Feed-forward surrogate emulating MHD sims at >98% fidelity — turnaround under 20 min.",
    highlight: ">98% fidelity", image: base + "LBFGS.png",
    tech: ["Neural Network", "MATLAB", "Python", "Plasma Physics"],
  },
  {
    index: "03", title: "E-Bike Boost Converter", status: null, href: "#",
    summary: "Designed, simulated, and tested a high-efficiency DC-DC boost for an e-bike battery.",
    highlight: "high-efficiency DC-DC boost", image: base + "BoostPCB.png",
    tech: ["LTspice", "KiCad", "Power Electronics", "PCB Design"],
  },
  {
    index: "05", title: "WLS Fiber Characterization", status: null, href: "#",
    summary: "Measured emission spectra and attenuation of WLS fibers for the LEGEND experiment.",
    highlight: null, image: base + "UVvBlueLED.png",
    tech: ["Optics", "SiPM", "Spectrometer", "Python", "DAQ"],
  },
] as const;

const phases = [
  { chip: "ACTIVE", title: "Ping-Pong Balancer", detail: "Assembling the 3-DoF platform; bringing up the vision + control loop.", state: "current" },
  { chip: "RESEARCH", title: "LEGEND detector R&D", detail: "WLS fiber characterization — published on arXiv.", state: "done" },
  { chip: "TEAM", title: "Longhorn Racing Electric", detail: "Steering + vehicle dynamics for the 2026 car.", state: "done" },
  { chip: "NEXT", title: "Aerospace & hardware roles", detail: "Tailoring the toolkit toward flight & advanced hardware.", state: "target" },
] as const;
---

<Base>
  <!-- ── HERO ─────────────────────────────────────────────────────────── -->
  <section class="hero">
    <div class="hero__grid blueprint" aria-hidden="true"></div>
    <div class="hero__spotlight" aria-hidden="true"></div>

    <div class="hero__inner container">
      <div>
        <Eyebrow dot color="accent">Portfolio · index 2026</Eyebrow>
        <h1 class="hero__title hero__title--type" data-typewriter aria-label="Hi, I'm Sivan Syed. Welcome to my corner of the internet.">
          <span class="tw-stage">
            <span class="tw-ghost" aria-hidden="true">Hi, I'm <span class="hero__title-accent">Sivan Syed</span>. Welcome to my corner of the internet.</span>
            <span class="tw-live" aria-hidden="true"><span class="tw-live__seg" data-seg="0" data-text="Hi, I'm "></span><span class="tw-live__seg hero__title-accent" data-seg="1" data-text="Sivan Syed"></span><span class="tw-live__seg" data-seg="2" data-text=". Welcome to my corner of the internet."></span><span class="tw-caret"></span></span>
          </span>
        </h1>
        <p class="hero__lead hero__lead--type">
          Here's a peek into my <a href="#primary" class="hero__dungeon">dungeon</a>: robots, circuits,
          and the occasional carbon-fiber experiment. Have a look around.
        </p>
        <div class="hero__actions">
          <Button variant="primary" size="lg" href="#primary">View the work →</Button>
          <Button variant="ghost" size="lg" href="#contact">Contact</Button>
        </div>
        <div class="hero__status">
          <span class="hero__pulse"></span>
          <span class="hero__status-text">
            Currently building <span class="accent">Ping-Pong Balancer</span> — 3-DoF vision-stabilized platform
          </span>
        </div>
      </div>

      <Panel reticle meta="SYS / NOMINAL" padding="24px">
        <div class="readout__label">Status readout</div>
        <div class="readout__kpis">
          <Kpi value="13" label="Projects logged" accent />
          <Kpi value="5" label="Domains" />
          <Kpi value="68" unit="%" label="FSAE mass cut" />
          <Kpi value=">98" unit="%" label="Model fidelity" />
        </div>
        <div class="readout__rule"></div>
        <div class="readout__rows">
          <div class="readout__row"><span class="readout__key">EDU</span><span class="readout__val">Physics + ECE · UT Austin</span></div>
          <div class="readout__row"><span class="readout__key">TEAM</span><span class="readout__val">Longhorn Racing Electric</span></div>
          <div class="readout__row"><span class="readout__key">LAB</span><span class="readout__val">LEGEND — arXiv:2509.20390</span></div>
        </div>
      </Panel>
    </div>
  </section>

  <!-- ── PRIMARY MISSIONS ─────────────────────────────────────────────── -->
  <section id="primary" class="section container">
    <SectionDivider />
    <div class="section__head">
      <div>
        <Eyebrow color="accent">Primary missions</Eyebrow>
        <h2 class="section__title">Flagship builds</h2>
      </div>
      <span class="section__aside">Dedicated case studies</span>
    </div>
    <div class="flagships">
      {featured.map((f) => <FeaturedProject {...f} />)}
    </div>
  </section>

  <!-- ── LAB LOG ──────────────────────────────────────────────────────── -->
  <section id="work" class="section container section--work">
    <SectionDivider />
    <div class="section__head section__head--stack">
      <Eyebrow color="accent">Lab log</Eyebrow>
      <h2 class="section__title">Side projects &amp; experiments</h2>
    </div>
    <div class="lab-grid">
      {projects.map((p) => <ProjectCard {...p} />)}
    </div>
  </section>

  <!-- ── ABOUT / NOW ──────────────────────────────────────────────────── -->
  <section id="about" class="section container">
    <SectionDivider />
    <div class="about">
      <div>
        <Eyebrow color="accent">The goal</Eyebrow>
        <h2 class="about__title">Push the boundaries of science and engineering</h2>
        <p class="about__body">
          I aim to contribute to bleeding-edge research and technology in
          physics-driven engineering — fields that demand both rigorous theoretical
          insight and innovative hardware. Whether it's condensed-matter physics,
          plasma, or robotics, I bridge theory with practical systems that ship.
        </p>
        <div class="about__tags">
          <Tag>Electronics hardware</Tag>
          <Tag>Computational engineering</Tag>
          <Tag>Robotics</Tag>
          <Tag>Aerospace</Tag>
        </div>
      </div>
      <Panel meta="MISSION PROFILE" padding="26px">
        <Eyebrow dot color="accent">Now</Eyebrow>
        <div class="about__traj">
          <Trajectory phases={phases} />
        </div>
      </Panel>
    </div>
  </section>

  <!-- ── CONTACT ──────────────────────────────────────────────────────── -->
  <section id="contact" class="section container">
    <SectionDivider />
    <div class="contact">
      <div>
        <Eyebrow color="accent">Open channel</Eyebrow>
        <h2 class="contact__title">Let's build something<br />on the edge.</h2>
        <p class="contact__body">
          Recruiting, collaborating, or just curious about a project? Send a transmission.
        </p>
        <div class="contact__rows">
          <div class="contact__row"><span class="contact__key">EMAIL</span><span class="contact__val">hello@ilgneous.dev</span></div>
          <div class="contact__row"><span class="contact__key">GITHUB</span><span class="contact__val">github.com/Ilgneous</span></div>
          <div class="contact__row"><span class="contact__key">BASE</span><span class="contact__val">Austin, TX</span></div>
        </div>
      </div>

      <Panel reticle meta="TX / READY" padding="28px">
        <form class="form" method="POST" action="#" onsubmit="return false;">
          <div class="form__pair">
            <label class="field">
              <span class="field__label">Name</span>
              <input class="field__input" type="text" name="name" placeholder="Your name" />
            </label>
            <label class="field">
              <span class="field__label">Email</span>
              <input class="field__input" type="email" name="email" placeholder="you@domain.com" />
            </label>
          </div>
          <label class="field">
            <span class="field__label">Subject</span>
            <input class="field__input" type="text" name="subject" placeholder="Role / project / hello" />
          </label>
          <label class="field">
            <span class="field__label">Message</span>
            <textarea class="field__input field__textarea" name="message" rows="4" placeholder="Tell me about the role or project…"></textarea>
          </label>
          <Button variant="primary" full type="submit">Transmit message</Button>
        </form>
      </Panel>
    </div>
  </section>
</Base>

<script>
  // Typewriter hero. The hidden .tw-ghost twin reserves the headline's exact
  // wrapped box. In the visible .tw-live layer we render EVERY character up
  // front (real spaces preserved, so line-wrapping is the final wrapping and is
  // computed once); typing only flips each character from hidden to shown via a
  // class, which changes color/opacity but never layout — so nothing reflows
  // and no word can jump as later characters appear.
  function runTypewriter() {
    const title = document.querySelector("[data-typewriter]");
    if (!title) return;

    const live = title.querySelector(".tw-live");
    const segs = Array.from(title.querySelectorAll(".tw-live__seg"));
    const caret = title.querySelector<HTMLElement>(".tw-caret");
    const lead = document.querySelector(".hero__lead--type");
    if (!live) return;

    function finish() {
      title!.classList.add("is-done");
      if (lead) lead.classList.add("is-shown");
    }

    // Flatten segments into characters, tagged with accent color, then build
    // one span per character. Real spaces stay as real text nodes so the
    // browser wraps exactly as it does for the ghost twin.
    live.textContent = "";
    const chars: { span: HTMLSpanElement; c: string }[] = [];
    for (let s = 0; s < segs.length; s++) {
      const text = segs[s].getAttribute("data-text") || "";
      const accent = segs[s].classList.contains("hero__title-accent");
      for (let j = 0; j < text.length; j++) {
        const c = text.charAt(j);
        const span = document.createElement("span");
        span.className = "tw-c is-pending";
        if (accent) span.classList.add("is-accent");
        span.textContent = c;
        live.appendChild(span);
        chars.push({ span: span, c: c });
      }
    }
    if (caret) live.appendChild(caret);

    // Position the caret (absolutely placed, out of flow) at the right edge of
    // the last revealed character. offsetLeft/Top are relative to .tw-live,
    // which is the caret's positioned ancestor, so the caret never disturbs the
    // character flow or wrapping.
    function placeCaret(n: number) {
      if (!caret) return;
      const ref = chars[n - 1];
      if (!ref) {
        caret.classList.remove("is-armed");
        return;
      }
      const el = ref.span;
      caret.style.left = (el.offsetLeft + el.offsetWidth) + "px";
      caret.style.top = el.offsetTop + "px";
      caret.classList.add("is-armed");
    }

    if (window.matchMedia("(prefers-reduced-motion: reduce)").matches) {
      for (let k = 0; k < chars.length; k++) chars[k].span.classList.remove("is-pending");
      placeCaret(chars.length);
      finish();
      return;
    }

    const punct = new Set([",", ".", "!", "?", "&"]);
    function delayFor(c: string) {
      let d = 42 + Math.random() * 38;
      if (punct.has(c)) d += 180;
      return d;
    }

    let i = 0;
    function step() {
      if (i >= chars.length) { finish(); return; }
      chars[i].span.classList.remove("is-pending");
      placeCaret(i + 1);
      const c = chars[i].c;
      i++;
      setTimeout(step, delayFor(c));
    }

    setTimeout(step, 360);
  }

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", runTypewriter, { once: true });
  } else {
    runTypewriter();
  }
</script>

<style>
  .container { max-width: var(--container); margin: 0 auto; }

  /* ── HERO ── */
  .hero { position: relative; overflow: hidden; padding: 72px 32px 56px; }
  .hero__grid {
    position: absolute;
    inset: 0;
    pointer-events: none;
    -webkit-mask-image: radial-gradient(120% 90% at 50% 0%, #000 35%, transparent 78%);
    mask-image: radial-gradient(120% 90% at 50% 0%, #000 35%, transparent 78%);
  }
  .hero__spotlight { position: absolute; inset: 0; pointer-events: none; background: var(--spotlight-ember); }
  .hero__inner {
    position: relative;
    display: grid;
    grid-template-columns: 1.55fr 1fr;
    gap: 48px;
    align-items: center;
  }
  .hero__title {
    font-size: clamp(44px, 6vw, 82px);
    font-weight: 600;
    line-height: 0.96;
    letter-spacing: -0.03em;
    color: var(--text-display);
    margin: 20px 0 0;
    font-feature-settings: var(--display-features);
  }
  .hero__title-accent { color: var(--accent); text-shadow: var(--glow-ember-text); }

  .tw-stage { position: relative; display: block; }
  .tw-ghost { visibility: hidden; }
  .tw-live {
    position: absolute;
    inset: 0;
    color: var(--text-display);
  }
  .tw-live__seg { color: inherit; }
  .tw-live__seg.hero__title-accent { color: var(--accent); text-shadow: var(--glow-ember-text); }
  /* Every character span is created by JS, so these rules must be :global —
     scoped Astro styles only match elements present at build time. Chars are
     present from the start so wrapping is final and stable; 'is-pending' chars
     are transparent (occupy space, invisible); accent chars are ember once shown. */
  :global(.tw-c) { color: var(--text-display); transition: color 90ms linear; }
  :global(.tw-c.is-accent) { color: var(--accent); text-shadow: var(--glow-ember-text); }
  :global(.tw-c.is-pending) { color: transparent; text-shadow: none; }
  .tw-caret {
    position: absolute;
    width: 0.06em;
    height: 0.92em;
    background: var(--accent);
    box-shadow: var(--glow-ember-text);
    border-radius: 1px;
    pointer-events: none;
    opacity: 0;
  }
  .hero__title--type .tw-caret.is-armed { opacity: 1; }
  .hero__title--type.is-done .tw-caret.is-armed { animation: ilg-caret-blink 1.05s steps(1, end) infinite; }
  @keyframes ilg-caret-blink {
    0%, 50% { opacity: 1; }
    50.01%, 100% { opacity: 0; }
  }
  .hero__lead {
    max-width: 52ch;
    margin-top: 22px;
    font-size: 17px;
    line-height: 1.6;
    color: var(--text-secondary);
  }
  .hero__lead--type {
    opacity: 0;
    transform: translateY(6px);
    transition: opacity var(--dur-slow) var(--ease-out), transform var(--dur-slow) var(--ease-out);
  }
  .hero__lead--type.is-shown { opacity: 1; transform: translateY(0); }
  .hero__dungeon {
    color: var(--text-secondary);
    font-weight: 600;
    text-decoration: underline;
    text-decoration-color: var(--accent-line);
    text-underline-offset: 3px;
    transition: color var(--dur-fast) var(--ease-out), text-decoration-color var(--dur-fast) var(--ease-out);
  }
  .hero__dungeon:hover { color: var(--text-accent); text-decoration-color: var(--accent); }

  @media (prefers-reduced-motion: reduce) {
    .hero__title--type .tw-caret.is-armed { animation: none !important; }
    .hero__lead--type { opacity: 1; transform: none; transition: none; }
  }
  .hero__actions { display: flex; gap: 14px; margin-top: 30px; flex-wrap: wrap; }
  .hero__status { display: flex; align-items: center; gap: 10px; margin-top: 34px; }
  .hero__pulse {
    width: 7px; height: 7px; border-radius: 99px;
    background: var(--accent);
    box-shadow: 0 0 0 0 var(--ember-glow);
    animation: ilg-pulse 2.4s var(--ease-out) infinite;
    flex-shrink: 0;
  }
  .hero__status-text {
    font-family: var(--font-mono);
    font-size: 12px;
    letter-spacing: 0.06em;
    color: var(--text-muted);
  }
  .hero__status-text .accent { color: var(--text-accent); }

  /* ── Status readout panel ── */
  .readout__label {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--text-faint);
    margin-bottom: 18px;
  }
  .readout__kpis { display: grid; grid-template-columns: 1fr 1fr; gap: 22px 18px; }
  .readout__rule { height: 1px; background: var(--hairline); margin: 20px 0; }
  .readout__rows { display: flex; flex-direction: column; gap: 8px; }
  .readout__row { display: flex; gap: 12px; font-family: var(--font-mono); font-size: 12px; }
  .readout__key { color: var(--text-faint); width: 40px; flex-shrink: 0; }
  .readout__val { color: var(--text-secondary); }

  /* ── Section scaffolding ── */
  .section { padding: 8px 32px; }
  .section--work { padding-bottom: 64px; }
  .section__head {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    flex-wrap: wrap;
    gap: 16px;
    margin-bottom: 28px;
  }
  .section__head--stack { display: block; }
  .section__title {
    font-size: clamp(30px, 4vw, 46px);
    font-weight: 600;
    letter-spacing: -0.025em;
    color: var(--text-display);
    margin: 14px 0 0;
  }
  .section__aside {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--text-faint);
    padding-bottom: 6px;
  }

  .flagships { display: flex; flex-direction: column; gap: 24px; }
  .lab-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 20px;
  }

  /* ── About ── */
  .about { display: grid; grid-template-columns: 1fr 1fr; gap: 48px; align-items: start; padding-top: 8px; }
  .about__title {
    font-size: clamp(28px, 3.4vw, 40px);
    font-weight: 600;
    letter-spacing: -0.025em;
    color: var(--text-display);
    margin: 14px 0 0;
    line-height: 1.1;
  }
  .about__body { font-size: 16px; line-height: 1.65; color: var(--text-secondary); margin-top: 18px; }
  .about__tags { display: flex; flex-wrap: wrap; gap: 8px; margin-top: 22px; }
  .about__traj { margin-top: 20px; }

  /* ── Contact ── */
  .contact { display: grid; grid-template-columns: 1fr 1.1fr; gap: 56px; align-items: center; padding: 20px 0; }
  .contact__title {
    font-size: clamp(30px, 4vw, 50px);
    font-weight: 600;
    letter-spacing: -0.03em;
    color: var(--text-display);
    margin: 14px 0 0;
    line-height: 1;
  }
  .contact__body { font-size: 16px; line-height: 1.6; color: var(--text-muted); margin-top: 18px; max-width: 42ch; }
  .contact__rows { display: flex; flex-direction: column; gap: 10px; margin-top: 24px; }
  .contact__row { display: flex; gap: 14px; font-family: var(--font-mono); font-size: 13px; }
  .contact__key { color: var(--text-faint); width: 56px; }
  .contact__val { color: var(--text-secondary); }

  /* ── Form ── */
  .form { display: flex; flex-direction: column; gap: 16px; }
  .form__pair { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }
  .field { display: flex; flex-direction: column; gap: var(--space-2); }
  .field__label {
    font-family: var(--font-mono);
    font-size: var(--text-2xs);
    text-transform: uppercase;
    letter-spacing: var(--tracking-label);
    color: var(--text-faint);
    transition: color var(--dur-fast) var(--ease-out);
  }
  .field:focus-within .field__label { color: var(--text-accent); }
  .field__input {
    width: 100%;
    height: var(--control-md);
    padding: 0 var(--space-3);
    font-family: var(--font-body);
    font-size: var(--text-sm);
    color: var(--text-primary);
    background: var(--surface-sunken);
    border: 1px solid var(--border-strong);
    border-radius: var(--radius-md);
    outline: none;
    transition: border-color var(--dur-fast) var(--ease-out), box-shadow var(--dur-fast) var(--ease-out);
  }
  .field__input:focus { border-color: var(--accent); box-shadow: 0 0 0 3px var(--accent-soft); }
