---
import "../styles/global.css";
import Counter from "../components/Counter.svelte";
import { getCollection } from "astro:content";
import ChargedField from "../components/ChargedField.svelte";
import SpaceBackground from "../components/SpaceBackground.svelte";


interface Project { title: string; href?: string; tech?: string[] }
const B = import.meta.env.BASE_URL;

// Choose API base: use env, else localhost in dev, else no API
const API =
  import.meta.env.PUBLIC_API_URL ??
  (import.meta.env.DEV ? "http://localhost:8000" : undefined);

let projects: Project[] = [];

if (API) {
  try {
    const r = await fetch(`${API}/api/projects`);
    if (r.ok) projects = await r.json();
  } catch {
    projects = [];
  }
}

if (projects.length === 0) {
  const entries = await getCollection("projects");
  projects = entries.map((e) => ({
    title: e.data.title,
    href: `/projects/${e.slug}`,
    tech: e.data.tech,
  }));
}

// Allowed dept values — add more in the .dept-* CSS block if needed
type Dept = "ECE" | "PHY" | "MATH" | "CS" | "ME" | "OTHER";
 
interface Course {
  code: string;       // e.g. "ECE 411"
  title: string;      // e.g. "Circuit Theory"
  dept: Dept;
  depth?: 1 | 2 | 3;  // optional emphasis (1=intro, 2=core, 3=advanced/grad)
  current?: boolean;  // currently enrolled
  honors?: boolean;
}
 
interface Term {
  label: string;      // e.g. "Fall 2025"
  status: "completed" | "current" | "upcoming";
  courses: Course[];
}
 
// Coursework Data — structured for easy rendering and stats, but could be manually edited or pulled from an API in the future
const terms: Term[] = [
  {
    label: "Spring 2026",
    status: "current",
    courses: [
      { code: "M 372K",  title: "Partial Differential Equations and Applications",dept: "MATH",   depth: 2, current: true },
      { code: "ECE 445L", title: "Embedded Systems Design Lab",  dept: "ECE",  depth: 3, current: true },
      { code: "ECE 396K",  title: "Magnetic Materials and Devices", dept: "ECE", depth: 3, current: true },
      { code: "PHY 389K",  title: "Quantum Mechanics I",dept: "PHY",   depth: 3, current: true },
    ],
  },
  {
    label: "Fall 2025",
    status: "completed",
    courses: [
      { code: "ECE 339",  title: "Solid-State Electronic Devices",          dept: "ECE",   depth: 2},
      { code: "ECE 438",  title: "Fundamentals of Electronic Circuits Lab",  dept: "ECE",  depth: 2 },
      { code: "PHY 381C", title: "Computational Physics",   dept: "PHY", depth: 3 },
      { code: "ECE 316",  title: "Digital Logic Design",    dept: "ECE",   depth: 1},
    ],
  },
  {
    label: "Spring 2025",
    status: "completed",
    courses: [
      { code: "ECE 319H", title: "Intro Embedded Systems: Honors",    dept: "ECE",  depth: 1, honors: true },
      { code: "ECE 411",  title: "Circuit Theory",  dept: "ECE", depth: 1 },
      { code: "M 365C",  title: "Real Analysis",dept: "MATH",   depth: 3 },
      { code: "PHY 369",  title: "Thermodynamics and Statistical Mechanics",dept: "PHY",   depth: 2 },
      { code: "ECE 312H",  title: "Software Design and Implementation I: Honors",dept: "ECE",   depth: 1, honors: true },
    ],
  },
  {
    label: "Fall 2024",
    status: "completed",
    courses: [
      { code: "ECE 302",title: "Intro to Electrical Engineering",   dept: "ECE",  depth: 1},
      { code: "PHY 336K",  title: "Classical Dynamics",      dept: "PHY", depth: 2 },
      { code: "PHY 336L",  title: "Fluid Dynamics",    dept: "PHY",   depth: 3 },
      { code: "ECE 306",title: "Introduction to Computing",   dept: "ECE",  depth: 1},
      { code: "M 361",  title: "Theory of Functions of Complex Variables",      dept: "MATH", depth: 2 },
      { code: "GER 322E",  title: "Conversation and Composition: Contemporary Controversies",    dept: "OTHER",   depth: 3 },
      { code: "MSE 360M",  title: "Experiments in Materials Science and Engineering",    dept: "OTHER",   depth: 2 },
    ],
  },
];
 
// Department palette mapping, used by the legend below
const deptInfo: Record<Dept, { label: string; classes: string }> = {
  ECE:    { label: "Electrical Eng.",  classes: "dept-ece" },
  PHY:   { label: "Physics",          classes: "dept-phy" },
  MATH:  { label: "Mathematics",      classes: "dept-math" },
  CS:    { label: "Computer Science", classes: "dept-cs" },
  ME:    { label: "Mechanical Eng.",  classes: "dept-me" },
  OTHER: { label: "Other",            classes: "dept-other" },
};
 
// Compute summary stats
const totalCourses = terms.reduce((n, t) => n + t.courses.length, 0);
const deptCounts = terms.flatMap(t => t.courses).reduce((acc, c) => {
  acc[c.dept] = (acc[c.dept] || 0) + 1;
  return acc;
}, {} as Record<string, number>);
const deptsRepresented = Object.keys(deptCounts).length;

---
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <title>Sivan Syed — Portfolio</title>
    <meta name="description" content="Physics & ECE • Robotics, controls, and systems." />
    <meta property="og:title" content="Sivan Syed — Portfolio" />
    <meta property="og:description" content="Physics & ECE • Robotics, controls, and systems." />
    <meta property="og:image" content={`/og.png`} />
    <link rel="icon" href={`/favicon.svg`} />
    <style>
      @media (prefers-reduced-motion: reduce) {
        .animate-shimmer { animation: none !important; }
      }
    </style>
  </head>
  <body class="min-h-screen overflow-x-hidden bg-gradient-to-b from-black via-zinc-950 to-black text-zinc-100 antialiased selection:bg-indigo-500/20 [padding-top:env(safe-area-inset-top)]">
    <a href="#main" class="sr-only focus:not-sr-only focus:fixed focus:left-3 focus:top-3 focus:z-[100] focus:rounded-md focus:bg-zinc-900 focus:px-3 focus:py-2 focus:outline-none">Skip to content</a>

    {/* Decorative background — shifted to blue/violet */}
    <SpaceBackground client:load />

    {/* Header */}
    <header class="sticky top-0 z-50 border-b border-zinc-800/60 backdrop-blur supports-[backdrop-filter]:bg-zinc-950/55">
      <div class="mx-auto flex max-w-7xl items-center justify-between gap-4 px-4 sm:px-6 md:px-12 lg:px-20 py-3 sm:py-4">
        <a href={`${B}`} class="group flex min-w-0 items-center gap-3">
          <img src={`/favicon.svg`} alt="Logo" class="size-9 flex-shrink-0 transition-transform duration-300 group-hover:rotate-6" />
          <div class="min-w-0">
            <h1 class="truncate text-xl font-semibold tracking-tight sm:text-2xl">Sivan Syed</h1>
            <p class="truncate text-[11px] text-zinc-400 sm:text-xs">Physics & ECE · Robotics · Controls · Systems</p>
          </div>
        </a>

        <nav class="hidden items-center gap-1 text-sm md:flex">
          <a class="navlink" href={`${B}`}>Home</a>
          <a class="navlink" href={`${B}projects`}>Projects</a>
          <a class="navlink" href={`${B}tutoring`}>Tutoring</a>
          <a class="navlink" href={`/SyedS_ResumeELC_Print.pdf`} target="_blank" rel="noopener noreferrer">Resume</a>
        </nav>

        {/* Mobile menu toggle */}
        <button id="mobile-nav-toggle" aria-controls="mobile-menu" aria-expanded="false" class="inline-flex items-center justify-center rounded-lg border border-zinc-800/60 bg-zinc-900/40 p-2 md:hidden" title="Open menu">
          <span class="sr-only">Open navigation</span>
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="h-5 w-5"><path d="M3.75 6.75h16.5M3.75 12h16.5M3.75 17.25h16.5"/></svg>
        </button>
      </div>

      <div id="mobile-menu" hidden class="md:hidden">
        <div class="mx-auto max-w-7xl px-4 sm:px-6 md:px-12 lg:px-20 pb-3">
          <nav class="grid gap-1 text-sm">
            <a class="navlink w-full" href={`${B}`}>Home</a>
            <a class="navlink w-full" href={`${B}projects`}>Projects</a>
            <a class="navlink w-full" href={`${B}tutoring`}>Tutoring</a>
            <a class="navlink w-full" href={`/SyedS_ResumeELC_Print.pdf`} target="_blank" rel="noopener noreferrer">Resume</a>
          </nav>
        </div>
      </div>
    </header>

    {/* Main */}
    <main id="main" class="mx-auto max-w-[90rem] px-4 sm:px-6 md:px-12 lg:px-20 py-8 sm:py-10 md:py-14 space-y-16 sm:space-y-20 md:space-y-24 scroll-mt-20">
      {/* Hero */}
      
<section class="relative isolate w-screen left-1/2 -translate-x-1/2 -mt-6 sm:-mt-8 md:-mt-10">
  <ChargedField
    client:load
    class="absolute inset-0 -z-10"
    density="med"
  />
 
  <div class="mx-auto max-w-6xl px-4 sm:px-6 md:px-12 lg:px-20">
    <div class="min-h-[min(88vh,860px)] flex items-center">
      <div class="max-w-3xl py-20 md:py-28">
        <p class="eyebrow-mono">Sivan Syed · Austin, TX</p>
 
        <h1 class="display mt-5 font-bold text-5xl sm:text-6xl md:text-7xl">
          <span class="block text-zinc-100">Theory.</span>
          <span class="block text-zinc-300/85">Computation.</span>
          <span class="block bg-gradient-to-r from-indigo-300 via-violet-200 to-indigo-300 bg-clip-text text-transparent">
            Working hardware.
          </span>
        </h1>
 
        <p class="mt-7 max-w-xl text-base sm:text-lg leading-relaxed text-zinc-300/85">
          Hi! I'm Sivan, an undergrad studying ECE, Physics, and Math at UT Austin. I created this site to share the 
          projects I'm working on, the things I'm learning, and the goals I'm building toward. I have a particular interest 
          in controls, robotics, aerospace, instrumentation, and experimental hardware design, but I'm always open to new problems that make me think.
          
          Feel free to explore, and if you want to chat about anything you see here, you can reach me at \*insert contact page\*!
        </p>
 
        <div class="mt-9 flex flex-wrap items-center gap-3">
          <a href={`${B}projects`} class="btn-primary"><span>Browse projects</span></a>
          <a href={`${B}tutoring`} class="btn-ghost"><span>Tutoring</span></a>
          <a href={`/SyedS_ResumeELC_Print.pdf`} class="btn-ghost"><span>Resume</span></a>
        </div>
 
        <p class="mt-12 font-mono text-[12px] sm:text-[13px] text-zinc-400/85">
          <span class="status-dot"></span>
          <span class="text-indigo-300/70">currently</span>
          <span class="opacity-50 mx-2">/</span>
          Intern at Emerson
          <span class="opacity-30 mx-2">·</span>
          Studying VLSI
          <span class="opacity-30 mx-2">·</span>
          Grad school applicant
        </p>
      </div>
    </div>
  </div>

              {/* Scroll cue — animated chevron at the bottom of the hero */}
  <div class="scroll-cue">
    <span>scroll</span>
    <svg class="scroll-cue-chevron" viewBox="0 0 14 14" fill="none" stroke="currentColor"
         stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
      <path d="M3 5 L7 9 L11 5"/>
    </svg>
  </div>
</section>
    
    {/*
      Add this to the existing inline <script is:inline> at the bottom of body.
      It just records the entry point of pointerenter so the liquid fill can
      expand from where the cursor actually crossed the button edge.
    */}
    <script is:inline>
      (function () {
        const els = document.querySelectorAll('.btn-primary, .btn-ghost');
        els.forEach((el) => {
          el.addEventListener('pointerenter', (e) => {
            const r = el.getBoundingClientRect();
            const x = ((e.clientX - r.left) / r.width) * 100;
            const y = ((e.clientY - r.top) / r.height) * 100;
            el.style.setProperty('--bx', x + '%');
            el.style.setProperty('--by', y + '%');
          });
        });
      })();
    </script>

      <hr class="section-divider-glow" />
---
// ════════════════════════════════════════════════════════════════════════
// REPLACEMENT for the "How I work" section in index.astro
// (the [EDIT 4] block from the v3 integration)
//
// Reordering:
//   01 — Theory → code      (now the tall feature card on the left)
//   02 — Simulate first     (top-right small)
//   03 — Systems & hardware (bottom-right small)
//   04 — Documenting        (wide bottom card, unchanged position)
//
// Reading flow: theory → simulate → build → document.
// ════════════════════════════════════════════════════════════════════════
---

<section class="section">
  <header class="mb-8 sm:mb-10">
    <p class="eyebrow-mono">// 01 — OPERATING PRINCIPLES</p>
    <h2 class="display mt-3 text-3xl sm:text-4xl font-bold text-zinc-100">
      How I work
    </h2>
    <p class="mt-3 max-w-2xl text-[15px] sm:text-base leading-relaxed text-zinc-300/80">
      A handful of principles I keep returning to, across every project &mdash; from
      detector simulations to balancing robots.
    </p>
  </header>

  <div class="grid grid-cols-1 md:grid-cols-3 md:grid-rows-2 gap-4 lg:gap-5">

    {/* ── 01 — Featured: Theory → code (tall, left, spans 2 rows on md+) ── */}
    <article class="panel md:row-span-2 flex flex-col">
      <span class="panel-bracket panel-bracket-tl"></span>
      <span class="panel-bracket panel-bracket-tr"></span>
      <span class="panel-bracket panel-bracket-bl"></span>
      <span class="panel-bracket panel-bracket-br"></span>
      <p class="panel-meta">[01 / 04]</p>

      <div class="panel-glyph mt-2 mb-6 w-16 h-16 sm:w-20 sm:h-20">
        <svg viewBox="0 0 64 64" class="w-full h-full">
          <text x="32" y="48" text-anchor="middle" font-size="48"
                fill="currentColor" font-family="ui-serif, Georgia, serif"
                font-style="italic" font-weight="400">∂</text>
        </svg>
      </div>

      <h3 class="display text-2xl sm:text-3xl font-semibold mb-3 text-zinc-100">
        Theory <span class="text-accent">&rarr;</span> code
      </h3>
      <p class="text-zinc-300/85 leading-relaxed text-[15px] flex-1">
        Every project starts as an equation. Lagrangians become state-space controllers,
        Maxwell becomes Verilog, transfer functions become PID gains you can actually tune.
        Most of the engineering work happens here &mdash; before any silicon is involved &mdash;
        translating math into something a computer can run.
      </p>

      <div class="mt-6 pt-4 border-t border-zinc-800/60">
        <p class="font-mono text-[10px] uppercase tracking-[0.18em] text-zinc-500">RECENT</p>
        <p class="font-mono text-[12px] text-indigo-300/70 mt-1.5">
          state-space ball balancer · digital filter design · MaGe geometries
        </p>
      </div>
    </article>

    {/* ── 02 — Simulate first ──────────────────────────────────────── */}
    <article class="panel flex flex-col">
      <span class="panel-bracket panel-bracket-tl"></span>
      <span class="panel-bracket panel-bracket-tr"></span>
      <span class="panel-bracket panel-bracket-bl"></span>
      <span class="panel-bracket panel-bracket-br"></span>
      <p class="panel-meta">[02 / 04]</p>

      <div class="panel-glyph mt-1 mb-3 w-12 h-12">
        <svg viewBox="0 0 64 64" fill="none" stroke="currentColor" stroke-width="1.5"
             stroke-linecap="round" class="w-full h-full">
          <line x1="4" y1="32" x2="60" y2="32" stroke-width="0.5"
                stroke-dasharray="2,3" opacity="0.5"/>
          <path d="M 4 32 Q 12 14, 20 32 T 36 32 T 52 32 T 60 32"/>
        </svg>
      </div>

      <h3 class="display text-lg sm:text-xl font-semibold mb-2 text-zinc-100">
        Simulate first
      </h3>
      <p class="text-zinc-300/85 leading-relaxed text-[14px]">
        I'd rather find a bug in a SPICE deck than on a $400 PCB. Phase portraits, FEA,
        MaGe geometries &mdash; laptops are where the iteration loop is fast.
      </p>
    </article>

    {/* ── 03 — Systems & hardware ──────────────────────────────────── */}
    <article class="panel flex flex-col">
      <span class="panel-bracket panel-bracket-tl"></span>
      <span class="panel-bracket panel-bracket-tr"></span>
      <span class="panel-bracket panel-bracket-bl"></span>
      <span class="panel-bracket panel-bracket-br"></span>
      <p class="panel-meta">[03 / 04]</p>

      <div class="panel-glyph mt-1 mb-3 w-12 h-12">
        <svg viewBox="0 0 64 64" fill="none" stroke="currentColor" stroke-width="1.25" class="w-full h-full">
          <circle cx="12" cy="12" r="2" fill="currentColor"/>
          <circle cx="52" cy="12" r="2" fill="currentColor"/>
          <circle cx="12" cy="52" r="2" fill="currentColor"/>
          <circle cx="52" cy="52" r="2" fill="currentColor"/>
          <circle cx="32" cy="32" r="2.5"/>
          <line x1="14" y1="12" x2="50" y2="12"/>
          <line x1="14" y1="52" x2="50" y2="52"/>
          <line x1="12" y1="14" x2="12" y2="50"/>
          <line x1="52" y1="14" x2="52" y2="50"/>
          <line x1="29.5" y1="32" x2="14" y2="32"/>
          <line x1="34.5" y1="32" x2="50" y2="32"/>
          <line x1="32" y1="29.5" x2="32" y2="14"/>
          <line x1="32" y1="34.5" x2="32" y2="50"/>
        </svg>
      </div>

      <h3 class="display text-lg sm:text-xl font-semibold mb-2 text-zinc-100">
        Systems &amp; <span class="text-accent">hardware</span>
      </h3>
      <p class="text-zinc-300/85 leading-relaxed text-[14px]">
        Where firmware meets a real motor and the math has to hold under load. Closed-loop
        controllers, instrumentation, embedded designs &mdash; things that have to keep
        working when nobody's watching.
      </p>
    </article>

    {/* ── 04 — Documenting the work (wide, spans 2 cols on md+) ────── */}
    <article class="panel md:col-span-2 flex flex-row gap-6 items-start">
      <span class="panel-bracket panel-bracket-tl"></span>
      <span class="panel-bracket panel-bracket-tr"></span>
      <span class="panel-bracket panel-bracket-bl"></span>
      <span class="panel-bracket panel-bracket-br"></span>
      <p class="panel-meta">[04 / 04]</p>

      <div class="panel-glyph flex-shrink-0 w-14 h-14 sm:w-16 sm:h-16">
        <svg viewBox="0 0 64 64" fill="none" stroke="currentColor" stroke-width="0.9" class="w-full h-full">
          <rect x="8" y="8" width="48" height="48"/>
          <line x1="8"  y1="20" x2="56" y2="20"/>
          <line x1="8"  y1="32" x2="56" y2="32"/>
          <line x1="8"  y1="44" x2="56" y2="44"/>
          <line x1="20" y1="8"  x2="20" y2="56"/>
          <line x1="32" y1="8"  x2="32" y2="56"/>
          <line x1="44" y1="8"  x2="44" y2="56"/>
          <circle cx="32" cy="32" r="4" stroke-width="1.4"/>
        </svg>
      </div>

      <div class="flex-1 min-w-0">
        <h3 class="display text-lg sm:text-xl font-semibold mb-2 text-zinc-100">
          Documenting the work
        </h3>
        <p class="text-zinc-300/85 leading-relaxed text-[14px] sm:text-[15px]">
          Hidden work is forgotten work. Half my engineering time is spent making the other
          half visible &mdash; clean diagrams, careful documentation, the writeup that
          explains why a loop needs these poles. It's how everything I build stays useful
          to the next person who picks it up.
        </p>
      </div>
    </article>

  </div>
</section>

      <hr class="section-divider-glow" />

      {/* Featured Projects */}
      <section class="section">
<header class="mb-6 sm:mb-8">
  <p class="eyebrow-mono">// 02 &mdash; FEATURED PROJECTS</p>
  <h3 class="display mt-3 text-2xl sm:text-3xl font-bold text-zinc-100">Recent builds</h3>
</header>        <div class="mt-5 grid grid-cols-1 gap-4 sm:mt-6 sm:gap-6 sm:grid-cols-2">
          {projects.slice(0, 6).map((p) => (
            <a href={p.href ?? '#'} class="card group block">
              <div class="card-border"></div>
              <div class="flex items-start justify-between gap-3">
                <h4 class="font-medium group-hover:text-indigo-200/90 transition-colors duration-200">{p.title}</h4>
                <span aria-hidden class="text-indigo-400/40 transition-all duration-300 group-hover:translate-x-0.5 group-hover:text-indigo-300/70">→</span>
              </div>
              {p.tech?.length ? (
                <ul class="mt-2 flex flex-wrap gap-2 text-xs text-zinc-400">
                  {p.tech.map((t) => (
                    <li class="tech-tag">{t}</li>
                  ))}
                </ul>
              ) : null}
            </a>
          ))}
        </div>
        <div class="mt-5 sm:mt-6">
          <a href={`${B}projects`} class="btn-ghost">See all projects</a>
        </div>
      </section>

      <hr class="section-divider-glow" />

      {/* Goals */}
      <section class="section">
  <header class="mb-8 sm:mb-10">
    <p class="eyebrow-mono">// 03 &mdash; MISSION PROFILE</p>
    <h2 class="display mt-3 text-3xl sm:text-4xl font-bold text-zinc-100">
      What I'm building toward
    </h2>
    <p class="mt-3 max-w-2xl text-[15px] sm:text-base leading-relaxed text-zinc-300/80">
      Here's the rough trajectory I'm aiming for over the next few years. The details will probably change, 
      but the general direction is what I'm trying to keep steady.
    </p>
  </header>
 
  <div class="grid grid-cols-1 lg:grid-cols-3 gap-5">
 
    {/* ── Trajectory — three vertical phases on the left, spans 2 cols on lg+ ── */}
    <div class="lg:col-span-2 panel">
      <span class="panel-bracket panel-bracket-tl"></span>
      <span class="panel-bracket panel-bracket-tr"></span>
      <span class="panel-bracket panel-bracket-bl"></span>
      <span class="panel-bracket panel-bracket-br"></span>
 
      <div class="flex items-center justify-between mb-7">
        <p class="font-mono text-[10px] uppercase tracking-[0.18em] text-zinc-500">TRAJECTORY</p>
        <p class="font-mono text-[10px] uppercase tracking-[0.18em] text-indigo-300/60">
          <span class="status-dot"></span>NOMINAL
        </p>
      </div>
 
      <ol class="trajectory">
 
        {/* ── Phase 1: Current ─────────────────────────────────────── */}
        <li class="phase phase-current">
          <div class="phase-rail">
            <span class="phase-marker"></span>
          </div>
          <div class="phase-body">
            <div class="flex items-baseline justify-between flex-wrap gap-2">
              <p class="font-mono text-[10px] uppercase tracking-[0.22em] text-indigo-300/80">
                PHASE 01 &middot; CURRENT ORBIT
              </p>
              <p class="font-mono text-[10px] text-zinc-500">[ACTIVE]</p>
            </div>
            <h3 class="display text-xl sm:text-2xl font-semibold mt-1.5 text-zinc-100">
              Building the foundation
            </h3>
            <p class="mt-2 text-[14px] sm:text-[15px] leading-relaxed text-zinc-300/85">
