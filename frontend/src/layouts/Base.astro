---
import "../styles/global.css";
import Button from "../components/ds/Button.astro";

interface NavLink { href: string; label: string; buttonVariant?: "primary" | "ghost" | "quiet" | "danger" | "signal"; }
interface Props {
  title?: string;
  description?: string;
  navLinks?: NavLink[];
  ctaHref?: string;
  ctaLabel?: string;
}
const {
  title = "Ilgneous — Physics + ECE portfolio",
  description = "Engineer building prototypes that merge mechanics, electronics, and software — across physics, plasma, robotics, and aerospace.",
  navLinks = [
    { href: "/#primary", label: "Work" },
    { href: "/#about", label: "About" },
    { href: "/resume", label: "Resume ↓", buttonVariant: "ghost" as const },
  ],
  ctaHref = "/#contact",
  ctaLabel = "Get in touch",
} = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/assets/favicon.svg" />
    <title>{title}</title>
    <meta name="description" content={description} />
  </head>
  <body>
    <header class="nav">
      <a href="/" class="nav__brand">
        <img src="/assets/logo-mark.svg" width="30" height="30" alt="" />
        <span class="nav__wordmark">ILG<span class="nav__wordmark-accent">NEOUS</span></span>
      </a>
      <button class="nav__hamburger" id="nav-toggle" aria-label="Toggle menu" aria-expanded="false">
        <span></span><span></span><span></span>
      </button>
      <nav class="nav__links" id="nav-menu">
        {navLinks.map((l) => l.buttonVariant
          ? <Button variant={l.buttonVariant} size="sm" href={l.href}>{l.label}</Button>
          : <a href={l.href} class="nav__link">{l.label}</a>
        )}
        <span class="nav__cta">
          <Button variant="signal" size="sm" href={ctaHref}>{ctaLabel}</Button>
        </span>
      </nav>
    </header>

    <script>
      const toggle = document.getElementById('nav-toggle');
      const menu = document.getElementById('nav-menu');
      toggle?.addEventListener('click', () => {
        const isOpen = menu?.classList.toggle('nav__links--open');
        toggle.setAttribute('aria-expanded', String(!!isOpen));
        toggle.classList.toggle('nav__hamburger--open', !!isOpen);
      });
      menu?.querySelectorAll('a').forEach(a => {
        a.addEventListener('click', () => {
          menu.classList.remove('nav__links--open');
          toggle?.setAttribute('aria-expanded', 'false');
          toggle?.classList.remove('nav__hamburger--open');
        });
      });
    </script>

    <main>
      <slot />
    </main>

    <footer class="footer">
      <div class="footer__inner">
        <div class="footer__brand">
          <img src="/assets/logo-mark.svg" width="24" height="24" alt="" />
          <span class="footer__wordmark">ILGNEOUS</span>
        </div>
        <span class="footer__meta">© 2026 · DESIGNED &amp; BUILT IN AUSTIN</span>
      </div>
    </footer>

    <style>
      .nav {
        position: sticky;
        top: 0;
        z-index: 50;
        display: flex;
        align-items: center;
        justify-content: space-between;
        flex-wrap: wrap;
        padding: 14px 32px;
        border-bottom: 1px solid var(--border);
        background: rgba(12, 14, 17, 0.78);
        backdrop-filter: blur(12px);
        -webkit-backdrop-filter: blur(12px);
      }
      .nav__brand { display: flex; align-items: center; gap: 11px; text-decoration: none; }
      .nav__wordmark {
        font-family: var(--font-display);
        font-size: 17px;
        font-weight: 600;
        letter-spacing: 0.02em;
        color: var(--text-display);
      }
      .nav__wordmark-accent { color: var(--accent); }
      .nav__links { display: flex; align-items: center; gap: 4px; }
      .nav__link {
        font-family: var(--font-mono);
        font-size: 12px;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        padding: 7px 12px;
        border-radius: 8px;
        color: var(--text-muted);
        text-decoration: none;
        transition: color var(--dur-fast) var(--ease-out), background var(--dur-fast) var(--ease-out);
      }
      .nav__link:hover { color: var(--text-display); background: var(--surface-raised); }
      .nav__cta { margin-left: 8px; }

      /* Hamburger — hidden on desktop */
      .nav__hamburger {
        display: none;
        flex-direction: column;
        justify-content: center;
        gap: 5px;
        width: 36px;
        height: 36px;
        padding: 6px;
        background: none;
        border: 1px solid var(--border);
        border-radius: var(--radius-sm);
        cursor: pointer;
      }
      .nav__hamburger span {
        display: block;
        height: 2px;
        background: var(--text-muted);
        border-radius: 2px;
        transition: transform 180ms var(--ease-out), opacity 180ms var(--ease-out);
      }
      .nav__hamburger--open span:nth-child(1) { transform: translateY(7px) rotate(45deg); }
      .nav__hamburger--open span:nth-child(2) { opacity: 0; }
      .nav__hamburger--open span:nth-child(3) { transform: translateY(-7px) rotate(-45deg); }

      .footer { border-top: 1px solid var(--border); background: var(--bg-void); margin-top: 24px; }
      .footer__inner {
        max-width: var(--container);
        margin: 0 auto;
        padding: 28px 32px;
        display: flex;
        justify-content: space-between;
        align-items: center;
        flex-wrap: wrap;
        gap: 16px;
      }
      .footer__brand { display: flex; align-items: center; gap: 11px; }
      .footer__wordmark {
        font-family: var(--font-display);
        font-size: 14px;
        font-weight: 600;
        color: var(--text-secondary);
      }
      .footer__meta {
        font-family: var(--font-mono);
        font-size: 11px;
        letter-spacing: 0.08em;
        color: var(--text-faint);
      }

      @media (max-width: 620px) {
        .nav { padding: 12px 18px; }
        .nav__hamburger { display: flex; }
        /* Mobile nav panel */
        .nav__links {
          display: none;
          flex-direction: column;
          align-items: stretch;
          width: 100%;
          order: 3;
          gap: 4px;
          padding: 12px 0 4px;
          border-top: 1px solid var(--border);
          margin-top: 12px;
        }
        .nav__links--open { display: flex; }
        .nav__link {
          padding: 10px 12px;
          font-size: 13px;
        }
        .nav__cta { margin-left: 0; margin-top: 4px; }
        /* Make buttons full-width on mobile */
        .nav__links :global(.btn) { width: 100%; justify-content: center; }

        .footer__inner { padding: 24px 18px; }
      }
    </style>
  </body>
</html>